<div class="min-h-screen bg-gray-100 flex items-center justify-center p-5">
  <div class="w-full max-w-md bg-white rounded-xl shadow-lg border border-gray-100 p-8 text-center">
    <div class="w-12 h-12 mx-auto rounded-xl bg-gray-200 grid place-items-center mb-4 text-lg">🔐</div>

    <h1 class="text-2xl font-black">Admin Login</h1>
    <p class="text-sm text-gray-500 mt-1 mb-6">Enter admin credentials to access the dashboard</p>

    <% if (locals.msg) { %>
      <div id="error-message" class="bg-red-50 border-l-4 border-red-500 p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <span class="text-red-500">⚠️</span>
          </div>
          <div class="ml-3 text-left">
            <p class="text-sm text-red-700 font-medium">
              <%= msg %>
            </p>
          </div>
        </div>
      </div>
    <% } %>

    <form method="POST" action="/admin/login" class="space-y-4 text-left">
      <div>
        <label class="block text-sm font-bold mb-2">Email Address</label>
        <input name="email" type="email" placeholder="admin@example.com" required
          class="w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 outline-none focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100"/>
      </div>

      <div>
        <label class="block text-sm font-bold mb-2">Password</label>
        <input name="password" type="password" placeholder="••••••••" required
          class="w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 outline-none focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100"/>
      </div>

      <button class="w-full rounded-lg bg-indigo-600 text-white font-black py-3 hover:bg-indigo-700 transition">
        Log In to Dashboard
      </button>
    </form>

    <div class="mt-8 pt-6 border-t border-gray-100">
      <p class="text-xs text-gray-400 font-bold uppercase tracking-widest">
        Authorized Access Only
      </p>
    </div>
  </div>
</div>