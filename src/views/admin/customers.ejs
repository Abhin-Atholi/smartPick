<div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 mb-6">
    <form action="/admin/customers" method="GET" class="flex flex-col md:flex-row gap-4">
    <div class="relative flex-1 group">
        <span class="absolute left-4 top-3 text-gray-400">🔍</span>
        
        <input name="search" id="searchInput" value="<%= currentSearch %>" type="text" 
            placeholder="Search users by name or email..." 
            class="w-full pl-10 pr-12 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all">
        
        <% if (currentSearch && currentSearch.length > 0) { %>
            <a href="/admin/customers?status=<%= currentStatus %>" 
               class="absolute right-4 top-2.5 w-6 h-6 flex items-center justify-center rounded-full bg-gray-200 text-gray-500 hover:bg-rose-500 hover:text-white transition-all text-xs font-bold"
               title="Clear search">
                ✕
            </a>
        <% } %>
    </div>

    <div class="flex gap-2">
        <select name="status" onchange="this.form.submit()"
            class="bg-gray-50 border border-gray-200 rounded-xl px-6 py-2.5 outline-none font-bold text-slate-700 cursor-pointer hover:border-indigo-300 transition-colors">
            <option value="All" <%= currentStatus === 'All' ? 'selected' : '' %>>All Statuses</option>
            <option value="Active" <%= currentStatus === 'Active' ? 'selected' : '' %>>Active</option>
            <option value="Blocked" <%= currentStatus === 'Blocked' ? 'selected' : '' %>>Blocked</option>
        </select>

        <button type="submit" class="px-6 py-2.5 bg-indigo-600 text-white font-black rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-100">
            SEARCH
        </button>
    </div>
</form>
</div>

<div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-gray-50 text-xs uppercase tracking-widest text-gray-400 font-black">
                    <th class="px-8 py-5">User</th>
                    <th class="px-6 py-5">Email</th>
                    <th class="px-6 py-5">Joined Date</th>
                    <th class="px-6 py-5 text-center">Status</th>
                    <th class="px-8 py-5 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                <% customers.forEach(customer => { %>
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="px-8 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full overflow-hidden border border-gray-100 shadow-sm bg-indigo-50 flex items-center justify-center shrink-0">
                                    <% if (customer.profileImage) { %>
                                        <img src="<%= customer.profileImage %>" alt="" class="w-full h-full object-cover">
                                    <% } else { %>
                                        <span class="font-bold text-indigo-600"><%= customer.fullName.charAt(0) %></span>
                                    <% } %>
                                </div>
                                <span class="font-bold text-slate-800 truncate max-w-[150px]"><%= customer.fullName %></span>
                            </div>
                        </td>

                        <td class="px-6 py-5 text-gray-500 font-medium lowercase italic text-sm">
                            <%= customer.email %>
                        </td>

                        <td class="px-6 py-5">
                            <p class="text-sm text-slate-700 font-bold">
                                <%= new Date(customer.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                            </p>
                            <p class="text-[10px] text-gray-400 font-medium">
                                <%= new Date(customer.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                            </p>
                        </td>

                        <td class="px-6 py-5 text-center">
                            <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider 
                                <%= customer.status === 'active' ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600' %>">
                                <%= customer.status %>
                            </span>
                        </td>

                        <td class="px-8 py-5 text-right">
                            <button onclick="toggleStatus('<%= customer._id %>')" 
                                class="px-5 py-2 rounded-xl font-black text-[10px] tracking-widest transition-all shadow-sm uppercase
                                <%= customer.status === 'active' ? 'bg-rose-500 text-white hover:bg-rose-600 shadow-rose-100' : 'bg-emerald-500 text-white hover:bg-emerald-600 shadow-emerald-100' %>">
                                <%= customer.status === 'active' ? 'Block' : 'Unblock' %>
                            </button>
                        </td>
                    </tr>
                <% }) %>
                <% if (customers.length === 0) { %>
                    <tr>
                        <td colspan="5" class="px-8 py-20 text-center">
                            <p class="text-gray-400 font-medium">No users found matching your criteria.</p>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <div class="px-8 py-5 border-t border-gray-50 flex flex-col sm:flex-row items-center justify-between gap-4 bg-gray-50/30">
        <p class="text-xs text-gray-500 font-bold uppercase tracking-tighter">
            Page <span class="text-indigo-600"><%= currentPage %></span> of <%= totalPages %>
        </p>
        
        <div class="flex items-center gap-1">
            <% if (currentPage > 1) { %>
                <a href="/admin/customers?page=<%= currentPage - 1 %>&search=<%= currentSearch %>&status=<%= currentStatus %>" 
                    class="p-2 bg-white border border-gray-200 rounded-lg hover:bg-gray-100 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </a>
            <% } %>

            <div class="flex gap-1 px-2">
                <% for(let i = 1; i <= totalPages; i++) { %>
                    <a href="/admin/customers?page=<%= i %>&search=<%= currentSearch %>&status=<%= currentStatus %>" 
                        class="w-8 h-8 flex items-center justify-center rounded-lg text-xs font-black transition <%= i === currentPage ? 'bg-indigo-600 text-white shadow-md' : 'text-gray-400 hover:text-indigo-600' %>">
                        <%= i %>
                    </a>
                <% } %>
            </div>

            <% if (currentPage < totalPages) { %>
                <a href="/admin/customers?page=<%= currentPage + 1 %>&search=<%= currentSearch %>&status=<%= currentStatus %>" 
                    class="p-2 bg-white border border-gray-200 rounded-lg hover:bg-gray-100 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
            <% } %>
        </div>
    </div>
</div>

<script>
async function toggleStatus(userId) {
    const { value: proceed } = await Swal.fire({
        title: 'User Access Update',
        text: "Are you sure you want to toggle this user's status?",
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#4f46e5',
        cancelButtonColor: '#94a3b8',
        confirmButtonText: 'Confirm Change',
        borderRadius: '1.25rem',
        customClass: {
            title: 'font-black text-slate-900',
            popup: 'rounded-3xl'
        }
    });

    if (proceed) {
        try {
            const response = await fetch(`/admin/customers/toggle/${userId}`, { 
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const result = await response.json();

            if (result.success) {
                Swal.fire({
                    title: 'Success!',
                    text: `User is now ${result.newStatus}.`,
                    icon: 'success',
                    timer: 1000,
                    showConfirmButton: false,
                    borderRadius: '1.25rem'
                }).then(() => window.location.reload());
            }
        } catch (error) {
            Swal.fire('Error!', 'Update failed.', 'error');
        }
    }
}
</script>