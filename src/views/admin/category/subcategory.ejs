<!-- Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-center justify-between">
        <div>
            <p class="text-sm text-gray-400 font-bold uppercase tracking-wider mb-1">Total Subcategories</p>
            <h3 class="text-3xl font-black text-slate-800">
                <%= typeof totalSubcategories !=='undefined' ? totalSubcategories : 0 %>
            </h3>
        </div>
        <div
            class="w-12 h-12 rounded-full bg-indigo-50 border border-indigo-100 flex items-center justify-center text-xl text-indigo-600">
            📑
        </div>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-center justify-between">
        <div>
            <p class="text-sm text-gray-400 font-bold uppercase tracking-wider mb-1">Active</p>
            <h3 class="text-3xl font-black text-slate-800">
                <%= typeof activeSubcategories !=='undefined' ? activeSubcategories : 0 %>
            </h3>
        </div>
        <div
            class="w-12 h-12 rounded-full bg-emerald-50 border border-emerald-100 flex items-center justify-center text-xl text-emerald-600">
            ✅
        </div>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-center justify-between">
        <div>
            <p class="text-sm text-gray-400 font-bold uppercase tracking-wider mb-1">Hidden</p>
            <h3 class="text-3xl font-black text-slate-800">
                <%= typeof hiddenSubcategories !=='undefined' ? hiddenSubcategories : 0 %>
            </h3>
        </div>
        <div
            class="w-12 h-12 rounded-full bg-rose-50 border border-rose-100 flex items-center justify-center text-xl text-rose-600">
            🚫
        </div>
    </div>
</div>

<div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 mb-6">
    <div class="flex flex-col md:flex-row gap-4 items-center justify-between mb-4">
        <h2 class="text-xl font-black text-slate-800">Subcategory Management</h2>
        <button onclick="openAddModal()"
            class="px-6 py-2.5 bg-indigo-600 text-white font-black rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-100 flex items-center gap-2">
            <span>+</span> Add Subcategory
        </button>
    </div>

    <form action="/admin/subcategory" method="GET" class="flex flex-col md:flex-row gap-4">
        <div class="relative flex-1 group">
            <span class="absolute left-4 top-3 text-gray-400">🔍</span>

            <input name="search" id="searchInput"
                value="<%= typeof currentSearch !== 'undefined' ? currentSearch : '' %>" type="text"
                placeholder="Search subcategories..."
                class="w-full pl-10 pr-12 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all">

            <% if (typeof currentSearch !=='undefined' && currentSearch && currentSearch.length> 0) { %>
                <a href="/admin/subcategory?status=<%= typeof currentStatus !== 'undefined' ? currentStatus : 'All' %>&parentCategory=<%= typeof currentParent !== 'undefined' ? currentParent : 'All' %>&sort=<%= typeof currentSort !== 'undefined' ? currentSort : 'createdAt' %>&order=<%= typeof currentOrder !== 'undefined' ? currentOrder : 'desc' %>"
                    class="absolute right-4 top-2.5 w-6 h-6 flex items-center justify-center rounded-full bg-gray-200 text-gray-500 hover:bg-rose-500 hover:text-white transition-all text-xs font-bold"
                    title="Clear search">
                    ✕
                </a>
                <% } %>
        </div>

        <div class="flex gap-2 flex-wrap sm:flex-nowrap">
            <select name="sort" onchange="document.getElementById('subcatOrderInput').value = this.options[this.selectedIndex].dataset.order; this.form.submit()" class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 outline-none font-bold text-slate-700 cursor-pointer hover:border-indigo-300 transition-colors w-full sm:w-auto">
                <option value="createdAt" data-order="desc" <%= typeof currentSort !== 'undefined' && currentSort === 'createdAt' && typeof currentOrder !== 'undefined' && currentOrder === 'desc' ? 'selected' : '' %>>Newest First</option>
                <option value="createdAt" data-order="asc" <%= typeof currentSort !== 'undefined' && currentSort === 'createdAt' && typeof currentOrder !== 'undefined' && currentOrder === 'asc' ? 'selected' : '' %>>Oldest First</option>
                <option value="name" data-order="asc" <%= typeof currentSort !== 'undefined' && currentSort === 'name' && typeof currentOrder !== 'undefined' && currentOrder === 'asc' ? 'selected' : '' %>>Name (A-Z)</option>
                <option value="name" data-order="desc" <%= typeof currentSort !== 'undefined' && currentSort === 'name' && typeof currentOrder !== 'undefined' && currentOrder === 'desc' ? 'selected' : '' %>>Name (Z-A)</option>
            </select>
            <input type="hidden" name="order" id="subcatOrderInput" value="<%= typeof currentOrder !== 'undefined' ? currentOrder : 'desc' %>">

            <select name="parentCategory" onchange="this.form.submit()"
                class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 outline-none font-bold text-slate-700 cursor-pointer hover:border-indigo-300 transition-colors w-full sm:w-auto">
                <option value="All" <%=typeof currentParent !=='undefined' && currentParent==='All' ? 'selected' : '' %>
                    >All Parent Categories</option>
                <% if(typeof categories !=='undefined' ) { %>
                    <% categories.forEach(cat=> { %>
                        <option value="<%= cat._id %>" <%=typeof currentParent !=='undefined' && currentParent==cat._id
                            ? 'selected' : '' %>><%= cat.name %>
                        </option>
                        <% }) %>
                            <% } %>
            </select>

            <select name="status" onchange="this.form.submit()"
                class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 outline-none font-bold text-slate-700 cursor-pointer hover:border-indigo-300 transition-colors w-full sm:w-auto">
                <option value="All" <%=typeof currentStatus !=='undefined' && currentStatus==='All' ? 'selected' : '' %>
                    >All Statuses</option>
                <option value="Active" <%=typeof currentStatus !=='undefined' && currentStatus==='Active' ? 'selected'
                    : '' %>>Active</option>
                <option value="Hidden" <%=typeof currentStatus !=='undefined' && currentStatus==='Hidden' ? 'selected'
                    : '' %>>Hidden</option>
            </select>

            <button type="submit"
                class="px-6 py-2.5 bg-indigo-600 text-white font-black rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-100 hidden sm:block">
                SEARCH
            </button>
        </div>
    </form>
</div>

<div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-gray-50 text-xs uppercase tracking-widest text-gray-400 font-black">
                    <th class="px-8 py-5">
                        <a href="?sort=name&order=<%= typeof currentSort !== 'undefined' && currentSort === 'name' && currentOrder === 'asc' ? 'desc' : 'asc' %>&search=<%= typeof currentSearch !== 'undefined' ? currentSearch : '' %>&status=<%= typeof currentStatus !== 'undefined' ? currentStatus : 'All' %>&parentCategory=<%= typeof currentParent !== 'undefined' ? currentParent : 'All' %>"
                            class="hover:text-indigo-600 transition-colors inline-flex items-center gap-1">
                            Subcategory Details
                            <% if (typeof currentSort !=='undefined' && currentSort==='name' ) { %>
                                <span class="text-indigo-600">
                                    <%= currentOrder==='desc' ? '↓' : '↑' %>
                                </span>
                                <% } %>
                        </a>
                    </th>
                    <th class="px-6 py-5">
                        Parent Category
                    </th>
                    <th class="px-6 py-5">Description</th>
                    <th class="px-6 py-5">
                        <a href="?sort=createdAt&order=<%= typeof currentSort !== 'undefined' && currentSort === 'createdAt' && currentOrder === 'asc' ? 'desc' : 'asc' %>&search=<%= typeof currentSearch !== 'undefined' ? currentSearch : '' %>&status=<%= typeof currentStatus !== 'undefined' ? currentStatus : 'All' %>&parentCategory=<%= typeof currentParent !== 'undefined' ? currentParent : 'All' %>"
                            class="hover:text-indigo-600 transition-colors inline-flex items-center gap-1">
                            Date Added
                            <% if (typeof currentSort==='undefined' || currentSort==='createdAt' ) { %>
                                <span class="text-indigo-600">
                                    <%= typeof currentOrder==='undefined' || currentOrder==='desc' ? '↓' : '↑' %>
                                </span>
                                <% } %>
                        </a>
                    </th>
                    <th class="px-6 py-5 text-center">Status</th>
                    <th class="px-8 py-5 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                <% if (typeof subcategories !=='undefined' && subcategories.length> 0) { %>
                    <% subcategories.forEach(subcategory=> { %>
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-3">
                                    <div
                                        class="w-12 h-12 rounded-xl overflow-hidden border border-gray-100 shadow-sm bg-indigo-50 flex items-center justify-center shrink-0">
                                        <% if (subcategory.image) { %>
                                            <img src="<%= subcategory.image %>" class="w-full h-full object-cover">
                                            <% } else { %>
                                                <span class="font-bold text-indigo-600 text-lg">
                                                    <%= subcategory.name.charAt(0).toUpperCase() %>
                                                </span>
                                                <% } %>
                                    </div>
                                    <span class="font-bold text-slate-800 truncate max-w-[150px]">
                                        <%= subcategory.name %>
                                    </span>
                                </div>
                            </td>

                            <td class="px-6 py-5">
                                <span
                                    class="px-3 py-1 bg-gray-100 text-gray-600 rounded-lg text-xs font-bold border border-gray-200">
                                    <%= subcategory.parentCategory && subcategory.parentCategory.name ?
                                        subcategory.parentCategory.name : 'Unknown Parent' %>
                                </span>
                            </td>

                            <td class="px-6 py-5 text-gray-500 font-medium text-sm truncate max-w-xs"
                                title="<%= subcategory.description %>">
                                <%- subcategory.description ? subcategory.description
                                    : '<span class="italic text-gray-300">No description</span>' %>
                            </td>

                            <td class="px-6 py-5">
                                <p class="text-sm text-slate-700 font-bold">
                                    <%= new Date(subcategory.createdAt).toLocaleDateString('en-GB', { day: '2-digit' ,
                                        month: 'short' , year: 'numeric' }) %>
                                </p>
                                <p class="text-[10px] text-gray-400 font-medium">
                                    <%= new Date(subcategory.createdAt).toLocaleTimeString([], { hour: '2-digit' ,
                                        minute: '2-digit' }) %>
                                </p>
                            </td>

                            <td class="px-6 py-5 text-center">
                                <span
                                    class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider inline-block
                                    <%= subcategory.isActive ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600' %>">
                                    <%= subcategory.isActive ? 'Active' : 'Hidden' %>
                                </span>
                            </td>

                            <td class="px-8 py-5 text-right">
                                <div class="flex justify-end items-center gap-2">
                                    <!-- Use encoded JSON strings so single quotes inside names don't break string boundaries natively -->
                                    <button onclick="openEditModal(<%= JSON.stringify({
                                        id: subcategory._id,
                                        name: subcategory.name,
                                        description: subcategory.description,
                                        isActive: subcategory.isActive,
                                        image: subcategory.image,
                                        parentId: subcategory.parentCategory ? subcategory.parentCategory._id : ''
                                    }) %>)"
                                        class="px-4 py-2 rounded-xl font-black text-[10px] tracking-widest transition-all shadow-sm uppercase bg-indigo-50 text-indigo-600 hover:bg-indigo-100 hover:text-indigo-700">
                                        Edit
                                    </button>
                                    <button
                                        onclick="toggleVisibility('<%= subcategory._id %>', <%= subcategory.isActive %>)"
                                        class="px-4 py-2 rounded-xl font-black text-[10px] tracking-widest transition-all shadow-sm uppercase
                                        <%= subcategory.isActive ? 'bg-rose-50 text-rose-600 hover:bg-rose-100' : 'bg-emerald-50 text-emerald-600 hover:bg-emerald-100' %>">
                                        <%= subcategory.isActive ? 'Hide' : 'Show' %>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="px-8 py-20 text-center">
                                        <p class="text-gray-400 font-medium">No subcategories found matching your
                                            criteria.</p>
                                    </td>
                                </tr>
                                <% } %>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div
        class="px-8 py-5 border-t border-gray-50 flex flex-col sm:flex-row items-center justify-between gap-4 bg-gray-50/30">
        <p class="text-xs text-gray-500 font-bold uppercase tracking-tighter">
            Page <span class="text-indigo-600">
                <%= typeof currentPage !=='undefined' ? currentPage : 1 %>
            </span> of <%= typeof totalPages !=='undefined' && totalPages> 0 ? totalPages : 1 %>
        </p>

        <div class="flex items-center gap-1">
            <% if (typeof currentPage !=='undefined' && currentPage> 1) { %>
                <a href="/admin/subcategory?page=<%= currentPage - 1 %>&sort=<%= typeof currentSort !== 'undefined' ? currentSort : 'createdAt' %>&order=<%= typeof currentOrder !== 'undefined' ? currentOrder : 'desc' %>&search=<%= typeof currentSearch !== 'undefined' ? currentSearch : '' %>&status=<%= typeof currentStatus !== 'undefined' ? currentStatus : 'All' %>&parentCategory=<%= typeof currentParent !== 'undefined' ? currentParent : 'All' %>"
                    class="p-2 bg-white border border-gray-200 rounded-lg hover:bg-gray-100 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7">
                        </path>
                    </svg>
                </a>
                <% } %>

                    <div class="flex gap-1 px-2">
                        <% if (typeof totalPages !=='undefined' && totalPages> 0) { %>
                            <% for(let i=1; i <=totalPages; i++) { %>
                                <a href="/admin/subcategory?page=<%= i %>&sort=<%= typeof currentSort !== 'undefined' ? currentSort : 'createdAt' %>&order=<%= typeof currentOrder !== 'undefined' ? currentOrder : 'desc' %>&search=<%= typeof currentSearch !== 'undefined' ? currentSearch : '' %>&status=<%= typeof currentStatus !== 'undefined' ? currentStatus : 'All' %>&parentCategory=<%= typeof currentParent !== 'undefined' ? currentParent : 'All' %>"
                                    class="w-8 h-8 flex items-center justify-center rounded-lg text-xs font-black transition <%= i === currentPage ? 'bg-indigo-600 text-white shadow-md' : 'text-gray-400 hover:text-indigo-600' %>">
                                    <%= i %>
                                </a>
                                <% } %>
                                    <% } %>
                    </div>

                    <% if (typeof currentPage !=='undefined' && typeof totalPages !=='undefined' && currentPage <
                        totalPages) { %>
                        <a href="/admin/subcategory?page=<%= currentPage + 1 %>&sort=<%= typeof currentSort !== 'undefined' ? currentSort : 'createdAt' %>&order=<%= typeof currentOrder !== 'undefined' ? currentOrder : 'desc' %>&search=<%= typeof currentSearch !== 'undefined' ? currentSearch : '' %>&status=<%= typeof currentStatus !== 'undefined' ? currentStatus : 'All' %>&parentCategory=<%= typeof currentParent !== 'undefined' ? currentParent : 'All' %>"
                            class="p-2 bg-white border border-gray-200 rounded-lg hover:bg-gray-100 transition">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7">
                                </path>
                            </svg>
                        </a>
                        <% } %>
        </div>
    </div>
</div>

<!-- Add Subcategory Modal -->
<div id="addSubcategoryModal"
    class="hidden fixed inset-0 z-[60] flex items-center justify-center overflow-y-auto overflow-x-hidden p-4">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity" onclick="closeAddModal()"></div>
    <div class="relative w-full max-w-2xl bg-white rounded-3xl shadow-2xl overflow-hidden transform transition-all">
        <div class="px-8 py-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
            <h3 class="text-xl font-black text-slate-800">Add New Subcategory</h3>
            <button onclick="closeAddModal()"
                class="text-gray-400 hover:text-rose-500 transition-colors bg-white hover:bg-rose-50 rounded-full w-8 h-8 flex items-center justify-center shadow-sm">✕</button>
        </div>

        <form id="addSubcategoryForm" class="p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Left Column -->
                <div class="space-y-6">
                    <div>
                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">Parent
                            Category</label>
                        <select name="parentCategory"
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold text-slate-700 cursor-pointer">
                            <option value="">Select a Parent Category...</option>
                            <% if(typeof categories !=='undefined' ) { %>
                                <% categories.forEach(cat=> { %>
                                    <option value="<%= cat._id %>">
                                        <%= cat.name %>
                                    </option>
                                    <% }) %>
                                        <% } %>
                        </select>
                        <p id="addSubcategoryParentError" class="error-text text-rose-500 text-xs font-bold mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">Subcategory
                            Name</label>
                        <input type="text" name="name" placeholder="e.g. Graphic Tees"
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold text-slate-700">
                        <p id="addSubcategoryNameError" class="error-text text-rose-500 text-xs font-bold mt-1 hidden"></p>
                    </div>
                    <div>
                        <label
                            class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">Description</label>
                        <textarea name="description" rows="3" placeholder="Brief description..."
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all text-sm font-medium text-slate-700"></textarea>
                        <p id="addSubcategoryDescError" class="error-text text-rose-500 text-xs font-bold mt-1 hidden"></p>
                    </div>

                    <div class="flex items-center gap-3 bg-gray-50 p-4 rounded-xl border border-gray-100">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="isActive" class="sr-only peer" checked>
                            <div
                                class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600">
                            </div>
                        </label>
                        <div>
                            <p class="text-sm font-black text-slate-700">Active Visibility</p>
                            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Show in storefront
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Right Column (Image Upload) -->
                <div>
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">Subcategory
                        Image</label>
                    <div
                        class="w-full flex-1 min-h-[220px] bg-gray-50 border-2 border-dashed border-gray-200 rounded-2xl hover:bg-gray-100 hover:border-indigo-300 transition-all flex flex-col items-center justify-center p-6 cursor-pointer relative group overflow-hidden">

                        <input type="file" name="image" id="subCategoryImage" accept="image/jpeg, image/png, image/webp"
                            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20">

                        <div id="uploadPrompt" class="text-center group-hover:scale-105 transition-transform z-10">
                            <div
                                class="w-12 h-12 bg-white rounded-full shadow-sm flex items-center justify-center mx-auto mb-3 text-indigo-500">
                                📸</div>
                            <p class="text-sm font-black text-slate-700">Upload Image</p>
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mt-1">PNG, JPG up to
                                2MB</p>
                        </div>

                        <div id="imagePreviewContainer"
                            class="absolute inset-0 z-10 hidden bg-white rounded-2xl overflow-hidden shadow-inner border border-gray-200">
                            <img id="imagePreview" src="" class="w-full h-full object-cover">
                            <div
                                class="absolute inset-0 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center pointer-events-none">
                                <span
                                    class="bg-white px-4 py-2 rounded-lg font-black text-xs text-slate-800 shadow-sm">Change
                                    Image</span>
                            </div>
                        </div>

                    </div>
                    <p id="addSubcategoryImageError" class="error-text text-rose-500 text-xs font-bold mt-2 hidden"></p>
                </div>
            </div>

            <div class="mt-8 flex justify-end gap-3 pt-6 border-t border-gray-50">
                <button type="button" onclick="closeAddModal()"
                    class="px-6 py-2.5 rounded-xl font-black text-sm text-gray-500 hover:bg-gray-100 transition">Cancel</button>
                <button type="submit" id="submitAddBtn"
                    class="px-6 py-2.5 bg-indigo-600 text-white font-black rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-100 pointer-events-auto">Create
                    Subcategory</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Subcategory Modal -->
<div id="editSubcategoryModal"
    class="hidden fixed inset-0 z-[60] flex items-center justify-center overflow-y-auto overflow-x-hidden p-4">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity" onclick="closeEditModal()"></div>
    <div class="relative w-full max-w-2xl bg-white rounded-3xl shadow-2xl overflow-hidden transform transition-all">
        <div class="px-8 py-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
            <h3 class="text-xl font-black text-slate-800">Edit Subcategory</h3>
            <button onclick="closeEditModal()"
                class="text-gray-400 hover:text-rose-500 transition-colors bg-white hover:bg-rose-50 rounded-full w-8 h-8 flex items-center justify-center shadow-sm">✕</button>
        </div>

        <form id="editSubcategoryForm" class="p-8">
            <input type="hidden" id="editSubcategoryId" name="subcategoryId">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Left Column -->
                <div class="space-y-6">
                    <div>
                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">Parent
                            Category</label>
                        <select id="editSubcategoryParent" name="parentCategory"
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold text-slate-700 cursor-pointer">
                            <option value="">Select a Parent Category...</option>
                            <% if(typeof categories !=='undefined' ) { %>
                                <% categories.forEach(cat=> { %>
                                    <option value="<%= cat._id %>">
                                        <%= cat.name %>
                                    </option>
                                    <% }) %>
                                        <% } %>
                        </select>
                        <p id="editSubcategoryParentError" class="error-text text-rose-500 text-xs font-bold mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">Subcategory
                            Name</label>
                        <input type="text" id="editSubcategoryName" name="name"
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold text-slate-700">
                        <p id="editSubcategoryNameError" class="error-text text-rose-500 text-xs font-bold mt-1 hidden"></p>
                    </div>
                    <div>
                        <label
                            class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">Description</label>
                        <textarea id="editSubcategoryDesc" name="description" rows="3"
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all text-sm font-medium text-slate-700"></textarea>
                        <p id="editSubcategoryDescError" class="error-text text-rose-500 text-xs font-bold mt-1 hidden"></p>
                    </div>
                    <div class="flex items-center gap-3 bg-gray-50 p-4 rounded-xl border border-gray-100">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="editSubcategoryActive" name="isActive" class="sr-only peer">
                            <div
                                class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600">
                            </div>
                        </label>
                        <div>
                            <p class="text-sm font-black text-slate-700">Active Visibility</p>
                            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Show in storefront
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Right Column -->
                <div>
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">Update
                        Image</label>
                    <div
                        class="w-full flex-1 min-h-[220px] bg-gray-50 border-2 border-dashed border-gray-200 rounded-2xl hover:bg-gray-100 hover:border-indigo-300 transition-all flex flex-col items-center justify-center p-6 cursor-pointer relative group overflow-hidden">

                        <input type="file" name="image" id="editSubcategoryImage"
                            accept="image/jpeg, image/png, image/webp"
                            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20">

                        <div id="editUploadPrompt"
                            class="text-center group-hover:scale-105 transition-transform z-10 hidden">
                            <div
                                class="w-12 h-12 bg-white rounded-full shadow-sm flex items-center justify-center mx-auto mb-3 text-indigo-500">
                                📸</div>
                            <p class="text-sm font-black text-slate-700">Upload New</p>
                        </div>

                        <div id="editImagePreviewContainer"
                            class="absolute inset-0 z-10 bg-white rounded-2xl overflow-hidden shadow-inner border border-gray-200">
                            <img id="editImagePreview" src="" class="w-full h-full object-cover">
                            <div
                                class="absolute inset-0 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center pointer-events-none">
                                <span
                                    class="bg-white px-4 py-2 rounded-lg font-black text-xs text-slate-800 shadow-sm">Replace
                                    Image</span>
                            </div>
                        </div>

                    </div>
                    <p id="editSubcategoryImageError" class="error-text text-rose-500 text-xs font-bold mt-2 hidden"></p>
                </div>
            </div>

            <div class="mt-8 flex justify-end gap-3 pt-6 border-t border-gray-50">
                <button type="button" onclick="closeEditModal()"
                    class="px-6 py-2.5 rounded-xl font-black text-sm text-gray-500 hover:bg-gray-100 transition">Cancel</button>
                <button type="submit" id="submitEditBtn"
                    class="px-6 py-2.5 bg-indigo-600 text-white font-black rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-100 pointer-events-auto">Update
                    Subcategory</button>
            </div>
        </form>
    </div>
</div>

<%- include("../partials/image-cropper") %>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script>
    let currentAddCropBlob = null;
    let currentEditCropBlob = null;

    async function toggleVisibility(subcategoryId, currentStatus) {
        const action = currentStatus ? 'hide' : 'show';
        const { value: proceed } = await Swal.fire({
            title: 'Subcategory Visibility',
            text: `Are you sure you want to ${action} this subcategory?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: currentStatus ? '#f43f5e' : '#10b981',
            cancelButtonColor: '#94a3b8',
            confirmButtonText: `Yes, ${action} it!`,
            borderRadius: '1.25rem',
            customClass: {
                title: 'font-black text-slate-900',
                popup: 'rounded-3xl'
            }
        });

        if (proceed) {
            try {
                const response = await fetch(`/admin/subcategory/toggle/${subcategoryId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' }
                });

                let result;
                try {
                    result = await response.json();
                } catch (e) {
                    throw new Error('Invalid JSON response');
                }

                if (result.success || response.ok) {
                    Swal.fire({
                        title: 'Success!',
                        text: `Subcategory has been ${action === 'hide' ? 'hidden' : 'shown'}.`,
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false,
                        borderRadius: '1.25rem'
                    }).then(() => window.location.reload());
                } else {
                    Swal.fire('Error!', result.message || 'Update failed.', 'error');
                }
            } catch (error) {
                console.error('Toggle status error:', error);
                Swal.fire('Error!', 'Something went wrong while toggling subcategory status.', 'error');
            }
        }
    }

    function openAddModal() {
        document.getElementById('addSubcategoryModal').classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
    }

    function closeAddModal() {
        document.getElementById('addSubcategoryModal').classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
        document.getElementById('addSubcategoryForm').reset();
        document.getElementById('imagePreviewContainer').classList.add('hidden');
        document.getElementById('uploadPrompt').classList.remove('hidden');
        currentAddCropBlob = null;
    }

    function openEditModal(subcategory) {
        document.getElementById('editSubcategoryId').value = subcategory.id;
        document.getElementById('editSubcategoryName').value = subcategory.name;
        document.getElementById('editSubcategoryParent').value = subcategory.parentId;
        document.getElementById('editSubcategoryDesc').value = subcategory.description;
        document.getElementById('editSubcategoryActive').checked = subcategory.isActive;

        if (subcategory.image) {
            document.getElementById('editImagePreview').src = subcategory.image;
            document.getElementById('editImagePreviewContainer').classList.remove('hidden');
            document.getElementById('editUploadPrompt').classList.add('hidden');
        } else {
            document.getElementById('editImagePreviewContainer').classList.add('hidden');
            document.getElementById('editUploadPrompt').classList.remove('hidden');
        }

        document.getElementById('editSubcategoryModal').classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
    }

    function closeEditModal() {
        document.getElementById('editSubcategoryModal').classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
        document.getElementById('editSubcategoryForm').reset();
        currentEditCropBlob = null;
    }

    // Modal Image Previews & Cropping
    document.getElementById('subCategoryImage').addEventListener('change', async function (e) {
        const file = e.target.files[0];
        if (file) {
            const validTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/jpg'];
            if (!validTypes.includes(file.type)) {
                e.target.value = '';
                return Swal.fire('Invalid File', 'Only JPEG, PNG, and WebP images are allowed.', 'warning');
            }
            if (file.size > 2 * 1024 * 1024) {
                e.target.value = '';
                return Swal.fire('File Too Large', 'Image size must be strictly under 2MB.', 'warning');
            }

            try {
                const croppedFile = await cropImage(file);
                currentAddCropBlob = croppedFile;
                document.getElementById('imagePreview').src = URL.createObjectURL(croppedFile);
                document.getElementById('imagePreviewContainer').classList.remove('hidden');
                document.getElementById('uploadPrompt').classList.add('hidden');
            } catch (err) {
                e.target.value = '';
            }
        }
    });

    document.getElementById('editSubcategoryImage').addEventListener('change', async function (e) {
        const file = e.target.files[0];
        if (file) {
            const validTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/jpg'];
            if (!validTypes.includes(file.type)) {
                e.target.value = '';
                return Swal.fire('Invalid File', 'Only JPEG, PNG, and WebP images are allowed.', 'warning');
            }
            if (file.size > 2 * 1024 * 1024) {
                e.target.value = '';
                return Swal.fire('File Too Large', 'Image size must be strictly under 2MB.', 'warning');
            }

            try {
                const croppedFile = await cropImage(file);
                currentEditCropBlob = croppedFile;
                document.getElementById('editImagePreview').src = URL.createObjectURL(croppedFile);
                document.getElementById('editImagePreviewContainer').classList.remove('hidden');
                document.getElementById('editUploadPrompt').classList.add('hidden');
            } catch (err) {
                e.target.value = '';
            }
        }
    });

    // Form Submissions via Axios
    document.getElementById('addSubcategoryForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        const form = e.target;
        const nameInput = form.name.value.trim();
        const parentInput = form.parentCategory.value;
        const descInput = form.description.value.trim();
        const imageFile = currentAddCropBlob || document.getElementById('subCategoryImage').files[0];

        document.querySelectorAll('#addSubcategoryForm .error-text').forEach(el => el.classList.add('hidden'));
        let isValid = true;

        if (!parentInput) {
            const err = document.getElementById('addSubcategoryParentError');
            err.textContent = 'Please select a Parent Category.';
            err.classList.remove('hidden');
            isValid = false;
        }
        if (nameInput.length < 3) {
            const err = document.getElementById('addSubcategoryNameError');
            err.textContent = 'Subcategory name must be at least 3 characters.';
            err.classList.remove('hidden');
            isValid = false;
        }
        if (descInput.length < 10) {
            const err = document.getElementById('addSubcategoryDescError');
            err.textContent = 'Description must be at least 10 characters long.';
            err.classList.remove('hidden');
            isValid = false;
        }
        if (!imageFile) {
            const err = document.getElementById('addSubcategoryImageError');
            err.textContent = 'Please upload an image banner.';
            err.classList.remove('hidden');
            isValid = false;
        }

        const validTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/jpg'];
        if (imageFile && !validTypes.includes(imageFile.type)) {
            const err = document.getElementById('addSubcategoryImageError');
            err.textContent = 'Only JPEG, PNG, and WebP images are allowed.';
            err.classList.remove('hidden');
            isValid = false;
        } else if (imageFile && imageFile.size > 2 * 1024 * 1024) {
            const err = document.getElementById('addSubcategoryImageError');
            err.textContent = 'Image size must be strictly under 2MB.';
            err.classList.remove('hidden');
            isValid = false;
        }

        if (!isValid) return;

        const submitBtn = document.getElementById('submitAddBtn');
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<span class="animate-spin inline-block mr-2">⏳</span> Saving...';
        submitBtn.disabled = true;

        const formData = new FormData(this);
        if (currentAddCropBlob) {
            formData.set('image', currentAddCropBlob);
        }

        try {
            const response = await axios.post('/admin/subcategory/add', formData, {
                headers: { 'Content-Type': 'multipart/form-data' }
            });

            if (response.data.success) {
                closeAddModal();
                Swal.fire({
                    title: 'Success!', text: 'Subcategory successfully added!', icon: 'success', timer: 2000, showConfirmButton: false, borderRadius: '1.25rem'
                }).then(() => window.location.reload());
            }
        } catch (error) {
            console.error('Add Subcategory Error:', error);
            const errorMsg = error.response?.data?.message || 'Something went wrong while saving.';
            Swal.fire('Error!', errorMsg, 'error');
        } finally {
            if (submitBtn) { submitBtn.innerHTML = originalText; submitBtn.disabled = false; }
        }
    });

    document.getElementById('editSubcategoryForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        const id = document.getElementById('editSubcategoryId').value;
        const nameInput = document.getElementById('editSubcategoryName').value.trim();
        const parentInput = document.getElementById('editSubcategoryParent').value;
        const descInput = document.getElementById('editSubcategoryDesc').value.trim();
        const imageFile = currentEditCropBlob || document.getElementById('editSubcategoryImage').files[0];

        document.querySelectorAll('#editSubcategoryForm .error-text').forEach(el => el.classList.add('hidden'));
        let isValid = true;

        if (!parentInput) {
            const err = document.getElementById('editSubcategoryParentError');
            err.textContent = 'Please select a Parent Category.';
            err.classList.remove('hidden');
            isValid = false;
        }
        if (nameInput.length < 3) {
            const err = document.getElementById('editSubcategoryNameError');
            err.textContent = 'Subcategory name must be at least 3 characters.';
            err.classList.remove('hidden');
            isValid = false;
        }
        if (descInput.length < 10) {
            const err = document.getElementById('editSubcategoryDescError');
            err.textContent = 'Description must be at least 10 characters long.';
            err.classList.remove('hidden');
            isValid = false;
        }

        if (imageFile) {
            const validTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/jpg'];
            if (!validTypes.includes(imageFile.type)) {
                const err = document.getElementById('editSubcategoryImageError');
                err.textContent = 'Only JPEG, PNG, and WebP images are allowed.';
                err.classList.remove('hidden');
                isValid = false;
            } else if (imageFile.size > 2 * 1024 * 1024) {
                const err = document.getElementById('editSubcategoryImageError');
                err.textContent = 'Image size must be strictly under 2MB.';
                err.classList.remove('hidden');
                isValid = false;
            }
        }

        if (!isValid) return;

        const submitBtn = document.getElementById('submitEditBtn');
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<span class="animate-spin inline-block mr-2">⏳</span> Updating...';
        submitBtn.disabled = true;

        const formData = new FormData(this);
        if (currentEditCropBlob) {
            formData.set('image', currentEditCropBlob);
        }

        try {
            const response = await axios.put(`/admin/subcategory/edit/${id}`, formData, {
                headers: { 'Content-Type': 'multipart/form-data' }
            });

            if (response.data.success) {
                closeEditModal();
                Swal.fire({
                    title: 'Updated!', text: 'Subcategory successfully updated!', icon: 'success', timer: 2000, showConfirmButton: false, borderRadius: '1.25rem'
                }).then(() => window.location.reload());
            }
        } catch (error) {
            console.error('Edit Subcategory Error:', error);
            const errorMsg = error.response?.data?.message || 'Something went wrong while updating.';
            Swal.fire('Error!', errorMsg, 'error');
        } finally {
            if (submitBtn) { submitBtn.innerHTML = originalText; submitBtn.disabled = false; }
        }
    });
</script>