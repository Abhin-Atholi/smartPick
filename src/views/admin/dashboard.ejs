<nav class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-6">
  Admin / <span class="text-indigo-600">Dashboard</span>
</nav>

<div class="mb-10">
  <h1 class="text-3xl font-black text-slate-900 tracking-tight">
  Welcome back, <%= (typeof admin !== 'undefined' && admin && admin.fullName) ? admin.fullName.split(' ')[0] : 'Admin' %>! 👋
</h1>
  <p class="text-gray-500 mt-2 font-medium">
    Here's what's happening with <span class="text-indigo-600 font-bold">SmartPick</span> today.
  </p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
  <% const skeletons = [
    { label: 'Total Revenue', icon: '💰' },
    { label: 'Active Orders', icon: '📦' },
    { label: 'New Customers', icon: '👥' },
    { label: 'Total Products', icon: '🏷️' }
  ] %>
  
  <% skeletons.forEach(item => { %>
    <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm transition-all hover:shadow-md">
      <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center text-xl mb-4">
        <%= item.icon %>
      </div>
      <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1"><%= item.label %></p>
      <div class="h-8 bg-gray-100 rounded-lg w-2/3 animate-pulse"></div>
    </div>
  <% }) %>
</div>

<div class="bg-white border-2 border-dashed border-gray-100 rounded-[2.5rem] min-h-[400px] flex flex-col items-center justify-center text-center p-12 transition-colors hover:border-indigo-200 group">
  <div class="w-24 h-24 bg-indigo-50 rounded-full grid place-items-center mb-6 group-hover:scale-110 transition-transform duration-500">
    <span class="text-4xl">📈</span>
  </div>
  
  <h2 class="text-2xl font-black text-slate-800 mb-3">Analytics are warming up</h2>
  <p class="text-gray-400 max-w-sm mb-8 font-medium leading-relaxed">
    Data for orders, sales trends, and customer behavior will appear here as your store grows.
  </p>
  
  <a href="/admin/customers" class="inline-flex items-center gap-2 px-8 py-4 bg-indigo-600 text-white font-black rounded-2xl hover:bg-indigo-700 hover:-translate-y-1 transition-all shadow-xl shadow-indigo-100 active:scale-95">
    <span>Manage Customers</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
    </svg>
  </a>
</div>