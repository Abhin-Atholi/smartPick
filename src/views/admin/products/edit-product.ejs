<!-- Cropper.js CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.css">
<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.js"></script>

<div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-2xl font-black text-slate-800">Edit Product</h2>
            <p class="text-sm text-gray-400 font-bold mt-0.5">Editing: <span class="text-indigo-600"><%= product.name %></span></p>
        </div>
        <a href="/admin/products" class="px-5 py-2 rounded-xl text-sm font-black text-gray-500 bg-white border border-gray-200 hover:bg-gray-50 transition flex items-center gap-2">
            ← Back to Products
        </a>
    </div>

    <form id="editProductForm">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- Left: Main Info -->
            <div class="lg:col-span-2 space-y-6">

                <!-- Basic Details Card -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 space-y-5">
                    <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest">Product Details</h3>
                    
                    <div>
                        <label class="block text-xs font-black text-gray-500 uppercase tracking-widest mb-2">Product Name *</label>
                        <input type="text" id="productName" name="name" value="<%= product.name %>"
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold text-slate-700 text-sm">
                        <p id="productNameError" class="error-text text-rose-500 text-xs font-bold mt-1 hidden"></p>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-black text-gray-500 uppercase tracking-widest mb-2">Brand</label>
                            <input type="text" id="productBrand" name="brand" value="<%= product.brand || '' %>"
                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold text-slate-700 text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-black text-gray-500 uppercase tracking-widest mb-2">Category *</label>
                            <select id="productCategory" name="category"
                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold text-slate-700 text-sm cursor-pointer">
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat._id %>" <%= product.category && product.category._id.toString() === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
                                <% }) %>
                            </select>
                            <p id="productCategoryError" class="error-text text-rose-500 text-xs font-bold mt-1 hidden"></p>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-black text-gray-500 uppercase tracking-widest mb-2">Subcategory</label>
                        <select id="productSubcategory" name="subcategory"
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold text-slate-700 text-sm cursor-pointer">
                            <option value="">None (optional)</option>
                            <% subcategories.forEach(sub => { %>
                                <option value="<%= sub._id %>" <%= product.subcategory && product.subcategory._id.toString() === sub._id.toString() ? 'selected' : '' %>><%= sub.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-black text-gray-500 uppercase tracking-widest mb-2">Description</label>
                        <textarea id="productDesc" name="description" rows="4"
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all text-sm font-medium text-slate-700 resize-none"><%= product.description || '' %></textarea>
                    </div>
                </div>

                <!-- Variants Card -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest">Product Variants *</h3>
                        <button type="button" onclick="addVariantRow()" class="px-4 py-2 bg-indigo-50 text-indigo-600 font-black text-xs rounded-xl hover:bg-indigo-100 transition">+ Add Variant</button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left" id="variantsTable">
                            <thead>
                                <tr class="text-[10px] uppercase tracking-widest text-gray-400 font-black border-b border-gray-100">
                                    <th class="pb-3 pr-3">Size</th>
                                    <th class="pb-3 pr-3">Color</th>
                                    <th class="pb-3 pr-3">Price (₹)</th>
                                    <th class="pb-3 pr-3">Stock</th>
                                    <th class="pb-3 pr-3">SKU (Auto)</th>
                                    <th class="pb-3"></th>
                                </tr>
                            </thead>
                            <tbody id="variantsBody"></tbody>
                        </table>
                    </div>
                    <p id="variantError" class="text-rose-500 text-xs font-bold mt-2 hidden">At least one complete variant is required.</p>
                </div>

            </div>

            <!-- Right: Images & Settings -->
            <div class="space-y-6">

                <!-- Existing Images -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                    <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Current Images</h3>
                    <div class="grid grid-cols-3 gap-2" id="existingImagesGrid">
                        <% product.images.forEach((img, i) => { %>
                            <div class="relative aspect-square rounded-xl overflow-hidden border border-gray-200 shadow-sm group" id="existing-img-<%= i %>" data-url="<%= img %>">
                                <img src="<%= img %>" class="w-full h-full object-cover">
                                <button type="button" onclick="removeExistingImage('<%= img %>', 'existing-img-<%= i %>')"
                                    class="absolute top-1 right-1 w-6 h-6 bg-rose-500 text-white rounded-full text-xs font-black flex items-center justify-center opacity-0 group-hover:opacity-100 transition">✕</button>
                            </div>
                        <% }) %>
                    </div>
                    <p id="existingCountMsg" class="text-xs font-bold mt-2 text-gray-400"><%= product.images.length %> existing image<%= product.images.length !== 1 ? 's' : '' %></p>
                </div>

                <!-- Add More Images -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                    <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Add More Images</h3>
                    <div class="border-2 border-dashed border-gray-200 rounded-2xl p-4 text-center hover:border-indigo-300 hover:bg-indigo-50/30 transition cursor-pointer" onclick="document.getElementById('imageFilePicker').click()">
                        <p class="text-3xl mb-1">+</p>
                        <p class="text-xs font-black text-slate-500">Upload & crop more images</p>
                        <input type="file" id="imageFilePicker" accept="image/*" multiple class="hidden">
                    </div>
                    <div id="newImagePreviewGrid" class="grid grid-cols-3 gap-2 mt-3"></div>
                    <p id="imageError" class="text-rose-500 text-xs font-bold mt-1 hidden">Total must be at least 3 images.</p>
                </div>

                <!-- Settings Card -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 space-y-4">
                    <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest">Settings</h3>
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-black text-slate-700">Active</p>
                            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Visible in storefront</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="productActive" name="isActive" class="sr-only peer" <%= product.isActive ? 'checked' : '' %>>
                            <div class="w-11 h-6 bg-gray-200 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                        </label>
                    </div>
                    <div class="flex items-center justify-between pt-2 border-t border-gray-50">
                        <div>
                            <p class="text-sm font-black text-slate-700">Featured ⭐</p>
                            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Show on homepage</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="productFeatured" name="isFeatured" class="sr-only peer" <%= product.isFeatured ? 'checked' : '' %>>
                            <div class="w-11 h-6 bg-gray-200 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-amber-500"></div>
                        </label>
                    </div>
                </div>

                <button type="button" onclick="submitEditForm()" id="submitProductBtn"
                    class="w-full py-3.5 bg-indigo-600 text-white font-black rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-100 text-sm">
                    Update Product
                </button>
            </div>
        </div>
    </form>
</div>

<!-- Cropper Modal -->
<div id="cropperModal" class="hidden fixed inset-0 z-[70] flex items-center justify-center p-4">
    <div class="fixed inset-0 bg-slate-900/70 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-3xl shadow-2xl w-full max-w-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
            <h3 class="font-black text-slate-800">Crop Image</h3>
            <span class="text-xs text-gray-400 font-bold">Drag to reposition • Scroll to zoom</span>
        </div>
        <div class="p-4 bg-gray-900 flex items-center justify-center" style="height:360px">
            <img id="cropperImage" src="" style="max-height:100%;max-width:100%;">
        </div>
        <div class="px-6 py-4 flex justify-end gap-3 border-t border-gray-100">
            <button onclick="cancelCrop()" class="px-5 py-2 rounded-xl font-black text-sm text-gray-500 hover:bg-gray-100 transition">Cancel</button>
            <button onclick="confirmCrop()" class="px-6 py-2.5 bg-indigo-600 text-white font-black rounded-xl hover:bg-indigo-700 transition text-sm">✓ Use This Crop</button>
        </div>
    </div>
</div>

<script>
    // Existing product data passed from EJS
    const existingVariants = <%- JSON.stringify(product.variants) %>;
    const productId = '<%= product._id %>';

    // ── Variant Management ──────────────────────────────────────────────────
    let variantCount = 0;
    let removedImages = [];
    let newCroppedBlobs = [];
    const PREDEFINED_COLORS = [
      { name: 'Black', code: '#000000' },
      { name: 'White', code: '#FFFFFF' },
      { name: 'Red', code: '#FF0000' },
      { name: 'Blue', code: '#0000FF' },
      { name: 'Green', code: '#008000' },
      { name: 'Yellow', code: '#FFFF00' },
      { name: 'Orange', code: '#FFA500' },
      { name: 'Purple', code: '#800080' },
      { name: 'Grey', code: '#808080' },
      { name: 'Navy', code: '#000080' }
    ];

    function addVariantRow(data = {}) {
        variantCount++;
        const row = document.createElement('tr');
        row.id = `variant-row-${variantCount}`;
        row.className = 'border-b border-gray-50 group';

        const sizeOptions = ["S", "M", "L", "XL"].map(s => `<option value="${s}" ${data.size === s ? 'selected' : ''}>${s}</option>`).join('');
        const colorOptions = PREDEFINED_COLORS.map(c => `
          <option value='${JSON.stringify(c)}' ${data.color && data.color.name === c.name ? 'selected' : ''}>
            ${c.name}
          </option>
        `).join('');

        row.innerHTML = `
            <td class="py-2 pr-3">
              <select class="w-16 px-2 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-xs font-bold text-slate-700 outline-none focus:ring-2 focus:ring-indigo-100 cursor-pointer" data-field="size">
                ${sizeOptions}
              </select>
            </td>
            <td class="py-2 pr-3">
              <div class="flex items-center gap-1.5">
                <select class="flex-1 px-2 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-xs font-bold text-slate-700 outline-none focus:ring-2 focus:ring-indigo-100 cursor-pointer" data-field="color" onchange="updateColorPreview(this)">
                  <option value="">Select Color</option>
                  ${colorOptions}
                </select>
                <div class="w-5 h-5 rounded-md border border-gray-100 color-preview" style="background-color: transparent"></div>
              </div>
            </td>
            <td class="py-2 pr-3"><input type="number" value="${data.price || ''}" placeholder="999" min="0" class="w-20 px-2 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-xs font-bold text-slate-700 outline-none focus:ring-2 focus:ring-indigo-100" data-field="price"></td>
            <td class="py-2 pr-3"><input type="number" value="${data.stock || ''}" placeholder="50" min="0" class="w-16 px-2 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-xs font-bold text-slate-700 outline-none focus:ring-2 focus:ring-indigo-100" data-field="stock"></td>
            <td class="py-2 pr-3">
                <span class="text-[10px] font-black text-gray-400 block max-w-[80px] truncate" title="${data.sku || 'Pending'}">${data.sku || 'Pending'}</span>
                <input type="hidden" value="${data.sku || ''}" data-field="sku">
            </td>
            <td class="py-2"><button type="button" onclick="document.getElementById('variant-row-${variantCount}').remove()" class="text-gray-300 hover:text-rose-500 transition font-black text-lg leading-none">✕</button></td>
        `;
        document.getElementById('variantsBody').appendChild(row);
        if (data.color) { updateColorPreview(row.querySelector('[data-field="color"]')); }
    }

    function updateColorPreview(select) {
      const preview = select.parentElement.querySelector('.color-preview');
      try {
        const color = JSON.parse(select.value);
        preview.style.backgroundColor = color.code;
      } catch { preview.style.backgroundColor = 'transparent'; }
    }

    function collectVariants() {
        const rows = document.querySelectorAll('#variantsBody tr');
        const variants = [];
        for (const row of rows) {
            const size = row.querySelector('[data-field="size"]')?.value.trim();
            const colorStr = row.querySelector('[data-field="color"]')?.value.trim();
            const price = parseFloat(row.querySelector('[data-field="price"]')?.value);
            const stock = parseInt(row.querySelector('[data-field="stock"]')?.value);
            const sku = row.querySelector('[data-field="sku"]')?.value || '';
            
            if (!size || !colorStr || isNaN(price) || isNaN(stock)) return null;
            
            try {
              const color = JSON.parse(colorStr);
              variants.push({ size, color, price, stock, sku });
            } catch { return null; }
        }
        return variants;
    }

    // Pre-load existing variants
    existingVariants.forEach(v => addVariantRow(v));

    // ── Existing Image Removal ───────────────────────────────────────────────
    function removeExistingImage(url, elementId) {
        removedImages.push(url);
        document.getElementById(elementId)?.remove();
        updateExistingCount();
    }

    function updateExistingCount() {
        const remaining = document.querySelectorAll('#existingImagesGrid [data-url]').length;
        document.getElementById('existingCountMsg').textContent = `${remaining} existing image${remaining !== 1 ? 's' : ''}`;
    }

    // ── Cropper for New Images ───────────────────────────────────────────────
    let cropperInstance = null;
    let pendingFiles = [];
    let pendingIndex = 0;

    document.getElementById('imageFilePicker').addEventListener('change', async (e) => {
        const files = Array.from(e.target.files);
        const validTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/jpg'];
        
        let validFiles = [];
        for (const file of files) {
            if (!validTypes.includes(file.type)) {
                await Swal.fire('Invalid File', `File "${file.name}" is not a valid image format.`, 'warning');
                continue;
            }
            if (file.size > 2 * 1024 * 1024) {
                await Swal.fire('File Too Large', `Image "${file.name}" exceeds the 2MB limit.`, 'warning');
                continue;
            }
            validFiles.push(file);
        }

        pendingFiles = validFiles;
        pendingIndex = 0;
        e.target.value = '';
        if (pendingFiles.length > 0) processNextPendingFile();
    });

    function processNextPendingFile() {
        if (pendingIndex >= pendingFiles.length) return;
        openCropper(pendingFiles[pendingIndex++]);
    }

    function openCropper(file) {
        const img = document.getElementById('cropperImage');
        img.src = URL.createObjectURL(file);
        document.getElementById('cropperModal').classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
        img.onload = () => {
            if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }
            cropperInstance = new Cropper(img, { aspectRatio: NaN, viewMode: 1, autoCropArea: 0.9 });
        };
    }

    function cancelCrop() { cleanupCropper(); processNextPendingFile(); }

    function confirmCrop() {
        if (!cropperInstance) return;
        cropperInstance.getCroppedCanvas({ maxWidth: 1200, maxHeight: 1200, fillColor: '#fff' }).toBlob((blob) => {
            const file = new File([blob], `product-img-${Date.now()}.jpg`, { type: 'image/jpeg' });
            newCroppedBlobs.push(file);
            const idx = newCroppedBlobs.length - 1;
            const src = URL.createObjectURL(blob);
            const grid = document.getElementById('newImagePreviewGrid');
            const div = document.createElement('div');
            div.id = `new-img-${idx}`;
            div.className = 'relative aspect-square rounded-xl overflow-hidden border border-gray-200 shadow-sm group';
            div.innerHTML = `<img src="${src}" class="w-full h-full object-cover"><button type="button" onclick="removeNewImage(${idx})" class="absolute top-1 right-1 w-6 h-6 bg-rose-500 text-white rounded-full text-xs font-black flex items-center justify-center opacity-0 group-hover:opacity-100 transition">✕</button>`;
            grid.appendChild(div);
            cleanupCropper();
            processNextPendingFile();
        }, 'image/jpeg', 0.9);
    }

    function removeNewImage(index) {
        newCroppedBlobs.splice(index, 1);
        document.getElementById(`new-img-${index}`)?.remove();
        const grid = document.getElementById('newImagePreviewGrid');
        Array.from(grid.children).forEach((div, i) => {
            div.id = `new-img-${i}`;
            div.querySelector('button').setAttribute('onclick', `removeNewImage(${i})`);
        });
    }

    function cleanupCropper() {
        if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }
        document.getElementById('cropperModal').classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
    }

    // ── Category AJAX ──────────────────────────────────────────────────────
    document.getElementById('productCategory').addEventListener('change', async function () {
        const catId = this.value;
        const subSelect = document.getElementById('productSubcategory');
        subSelect.innerHTML = '<option value="">Loading...</option>';
        if (!catId) { subSelect.innerHTML = '<option value="">Select category first...</option>'; return; }
        try {
            const res = await axios.get(`/admin/products/subcategories/${catId}`);
            if (res.data.success && res.data.subcategories.length > 0) {
                subSelect.innerHTML = '<option value="">None (optional)</option>' +
                    res.data.subcategories.map(s => `<option value="${s._id}">${s.name}</option>`).join('');
            } else {
                subSelect.innerHTML = '<option value="">No subcategories available</option>';
            }
        } catch {
            subSelect.innerHTML = '<option value="">Error loading subcategories</option>';
        }
    });

    // ── Submit ──────────────────────────────────────────────────────────────
    async function submitEditForm() {
        const name = document.getElementById('productName').value.trim();
        const category = document.getElementById('productCategory').value;
        const variants = collectVariants();

        document.querySelectorAll('#editProductForm .error-text').forEach(el => el.classList.add('hidden'));
        document.getElementById('imageError').classList.add('hidden');
        document.getElementById('variantError').classList.add('hidden');

        let valid = true;
        
        if (name.length < 2) { 
            const err = document.getElementById('productNameError');
            err.textContent = 'Product name must be at least 2 characters.';
            err.classList.remove('hidden');
            valid = false;
        }
        if (!category) { 
            const err = document.getElementById('productCategoryError');
            err.textContent = 'Please select a category.';
            err.classList.remove('hidden');
            valid = false;
        }

        const existingCount = document.querySelectorAll('#existingImagesGrid [data-url]').length;
        const totalImages = existingCount + newCroppedBlobs.length;
        if (totalImages < 3) {
            document.getElementById('imageError').classList.remove('hidden');
            valid = false;
        }

        if (variants === null || variants.length === 0) {
            document.getElementById('variantError').classList.remove('hidden');
            valid = false;
        }

        if (!valid) return;

        const btn = document.getElementById('submitProductBtn');
        btn.innerHTML = '⏳ Updating...'; btn.disabled = true;

        try {
            const formData = new FormData();
            formData.append('name', name);
            formData.append('brand', document.getElementById('productBrand').value.trim());
            formData.append('category', category);
            formData.append('subcategory', document.getElementById('productSubcategory').value);
            formData.append('description', document.getElementById('productDesc').value.trim());
            formData.append('isActive', document.getElementById('productActive').checked ? 'on' : 'false');
            formData.append('isFeatured', document.getElementById('productFeatured').checked ? 'on' : 'false');
            formData.append('variants', JSON.stringify(variants));
            formData.append('removedImages', JSON.stringify(removedImages));
            newCroppedBlobs.forEach(blob => formData.append('images', blob));

            const res = await axios.put(`/admin/products/edit/${productId}`, formData, { headers: { 'Content-Type': 'multipart/form-data' } });
            if (res.data.success) {
                Swal.fire({ title: 'Updated!', text: 'Product updated successfully!', icon: 'success', timer: 2000, showConfirmButton: false })
                    .then(() => window.location.href = '/admin/products');
            }
        } catch (err) {
            Swal.fire('Error!', err.response?.data?.message || 'Something went wrong.', 'error');
        } finally {
            btn.innerHTML = 'Update Product'; btn.disabled = false;
        }
    }
</script>
