<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-sm bg-white rounded-2xl shadow-lg p-8">

    <h2 class="text-2xl font-black text-center mb-2">Verify Account</h2>

    <p class="text-sm text-gray-500 text-center mb-4">
      Enter the 6-digit OTP sent to your email
    </p>

    <div class="mb-6 text-center">
      <span class="text-xs font-bold uppercase tracking-wider text-gray-400">OTP Expires In</span>
      <div id="expiryTimer" class="text-2xl font-mono font-bold text-indigo-600">03:00</div>
    </div>

    <% if (msg) { %>
      <div class="mb-4 text-sm text-red-500 text-center font-semibold">
        <%= msg %>
      </div>
    <% } %>

    <form method="POST" action="/verify" class="space-y-4">
      <input type="hidden" name="email" value="<%= email %>">

      <div>
        <label class="block text-sm font-semibold mb-2">OTP Code</label>
        <input
          type="text"
          name="otp"
          id="otpInput"
          maxlength="6"
          placeholder="Enter 6-digit OTP"
          required
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-center text-lg tracking-widest outline-none focus:ring-2 focus:ring-indigo-500"
        >
      </div>

      <button
        id="verifyBtn"
        type="submit"
        class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-3 rounded-xl transition disabled:bg-gray-400"
      >
        Verify
      </button>
    </form>

    <form method="POST" action="/resend-otp" class="mt-4">
      <input type="hidden" name="email" value="<%= email %>">
      <button
        id="resendBtn"
        type="submit"
        class="w-full border border-gray-200 rounded-xl py-3 font-black text-sm hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Resend OTP <span id="timerText"></span>
      </button>
    </form>

    <div class="mt-6 text-center text-sm">
      <a href="/login" class="text-indigo-600 font-semibold hover:underline">
        Back to Login
      </a>
    </div>
  </div>
</div>

<script>
  // Ensure we get a valid number from the backend
  let timeLeft = parseInt("<%= remainingSeconds %>") || 0;

  const expiryDisplay = document.getElementById("expiryTimer");
  const resendBtn = document.getElementById("resendBtn");
  const resendTimerText = document.getElementById("timerText"); // Matches HTML now
  const verifyBtn = document.getElementById("verifyBtn");
  const otpInput = document.getElementById("otpInput");

  function startCountdown() {
    const timerInterval = setInterval(() => {
      if (timeLeft <= 0) {
        clearInterval(timerInterval);
        
        expiryDisplay.textContent = "EXPIRED";
        expiryDisplay.style.color = "red";
        
        // Disable verification inputs
        if(verifyBtn) verifyBtn.disabled = true;
        if(otpInput) otpInput.disabled = true;

        // Unlock resend button
        resendBtn.disabled = false;
        resendTimerText.textContent = ""; 
      } else {
        const m = Math.floor(timeLeft / 60);
        const s = timeLeft % 60;
        expiryDisplay.textContent = `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
        
        // Lock resend button
        resendBtn.disabled = true;
        resendTimerText.textContent = ` (Wait ${timeLeft}s)`;
        
        timeLeft--;
      }
    }, 1000);
  }

  // Initial Check
  if (timeLeft > 0) {
    startCountdown();
  } else {
    expiryDisplay.textContent = "EXPIRED";
    expiryDisplay.style.color = "red";
    resendBtn.disabled = false;
    if(verifyBtn) verifyBtn.disabled = true;
  }
</script>