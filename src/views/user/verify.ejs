<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-sm bg-white rounded-2xl shadow-lg p-8">

    <h2 class="text-2xl font-black text-center mb-2">Verify Account</h2>

    <p class="text-sm text-gray-500 text-center mb-6">
      Enter the 6-digit OTP sent to your email
    </p>

    <% if (msg) { %>
      <div class="mb-4 text-sm text-red-500 text-center font-semibold">
        <%= msg %>
      </div>
    <% } %>

    <!-- VERIFY OTP -->
    <form method="POST" action="/verify" class="space-y-4">
      <input type="hidden" name="email" value="<%= email %>">

      <div>
        <label class="block text-sm font-semibold mb-2">OTP Code</label>
        <input
          type="text"
          name="otp"
          maxlength="6"
          placeholder="Enter 6-digit OTP"
          required
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-center text-lg tracking-widest outline-none focus:ring-2 focus:ring-indigo-500"
        >
      </div>

      <button
        type="submit"
        class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-3 rounded-xl transition"
      >
        Verify
      </button>
    </form>

    <!-- RESEND OTP -->
    <form method="POST" action="/resend-otp" class="mt-4">
      <input type="hidden" name="email" value="<%= email %>">
      <button
        id="resendBtn"
        type="submit"
        class="w-full border border-gray-200 rounded-xl py-3 font-black text-sm hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Resend OTP <span id="timerText"></span>
      </button>
    </form>

    <div class="mt-6 text-center text-sm">
      <a href="/login" class="text-indigo-600 font-semibold hover:underline">
        Back to Login
      </a>
    </div>
  </div>
</div>

<script>
  // ✅ comes from backend render; if not passed, it becomes 0
  let seconds = <%= (typeof waitSeconds !== "undefined" && waitSeconds) ? waitSeconds : 0 %>;

  const btn = document.getElementById("resendBtn");
  const timerText = document.getElementById("timerText");

  function tick() {
    if (!btn) return;

    if (seconds > 0) {
      btn.disabled = true;
      timerText.textContent = `(${seconds}s)`;
      seconds--;
      setTimeout(tick, 1000);
    } else {
      btn.disabled = false;
      timerText.textContent = "";
    }
  }

  tick();
</script>
