<%- include("partials/navbar") %>

  <section class="max-w-6xl mx-auto px-4 py-8">
    <%- include("partials/accountHeader", { breadcrumb: 'Saved Addresses' }) %>

      <div class="grid lg:grid-cols-[280px_1fr] gap-6">
        <aside>
          <%- include("partials/accountSidebar", { active: "addresses" }) %>
        </aside>

        <main class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden">
          <div class="p-6 border-b border-gray-100 flex justify-between items-center">
            <div>
              <h2 class="text-xl font-black">Your Addresses</h2>
              <p class="text-sm text-gray-500 mt-1">Add, edit or remove your shipping addresses.</p>
            </div>
            <button onclick="openAddModal()"
              class="px-5 py-2 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition active:scale-95">
              + Add Address
            </button>
          </div>

          <div class="p-6">
            <% if (typeof msg !=="undefined" && msg) { %>
              <div
                class="mb-6 p-4 text-sm font-bold rounded-xl <%= msg.includes('successfully') || msg.includes('deleted') ? 'bg-green-50 text-green-700 border border-green-100' : 'bg-red-50 text-red-700 border border-red-100' %>">
                <%= msg %>
              </div>
              <% } %>

                <div class="grid md:grid-cols-2 gap-6">
                  <% (addresses || []).forEach(a=> { %>
                    <div
                      class="rounded-2xl border border-indigo-100 bg-indigo-50/30 p-5 flex flex-col justify-between hover:border-indigo-200 transition-colors">
                      <div>
                        <div class="flex justify-between items-start">
                          <div class="font-black text-indigo-700 text-lg flex items-center gap-2">
                            <%= a.fullName %>
                            <% if (a.isDefault) { %>
                              <span class="px-2 py-0.5 rounded text-xs font-bold bg-indigo-600 text-white shadow-sm">Default</span>
                            <% } %>
                          </div>
                          <div class="flex items-center gap-3">
                            <button onclick="openEditModal(this)" data-id="<%= a._id %>"
                              data-fullname="<%= a.fullName %>" data-phone="<%= a.phone %>"
                              data-pincode="<%= a.pincode %>" data-state="<%= a.state %>" data-city="<%= a.city %>"
                              data-locality="<%= a.locality %>" data-house="<%= a.house %>" data-area="<%= a.area %>"
                              data-isdefault="<%= a.isDefault ? 'true' : 'false' %>"
                              class="text-indigo-600 text-sm font-black hover:underline">
                              ✎ Edit
                            </button>
                            <button onclick="confirmDelete(event, '<%= a._id %>')"
                                class="text-gray-400 hover:text-red-500 transition-colors">
                              <span>&#x1F5D1;delete</span>
                            </button>
                          </div>
                        </div>

                        <div class="text-indigo-700 text-sm mt-1 font-semibold">
                          <%= a.phone %>
                        </div>

                        <div class="text-gray-600 text-sm mt-4 leading-relaxed">
                          <div class="font-medium text-gray-800">
                            <%= a.house %>
                          </div>
                          <div>
                            <%= a.area %>
                          </div>
                          <div>
                            <%= a.locality %>, <%= a.city %>
                          </div>
                          <div>
                            <%= a.state %> - <span class="font-bold text-gray-900">
                                <%= a.pincode %>
                              </span>
                          </div>
                        </div>
                      </div>
                    </div>
                    <% }) %>

                      <% if (addresses.length===0) { %>
                        <div class="md:col-span-2 py-12 text-center border-2 border-dashed border-gray-100 rounded-2xl">
                          <p class="text-gray-400 font-medium">No addresses saved yet.</p>
                          <button onclick="openAddModal()"
                            class="mt-4 text-sm text-indigo-600 font-bold hover:underline">+ Add your first
                            address</button>
                        </div>
                        <% } %>
                </div>
          </div>
        </main>
      </div>
  </section>

  <%- include("partials/footer") %>
  <%- include("partials/drawer") %>

  <%- include("partials/addressModals") %>