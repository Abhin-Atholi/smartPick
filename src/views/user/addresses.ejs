<%- include("../partials/navbar") %>

<div class="max-w-6xl mx-auto px-4 py-10">
  <div class="grid lg:grid-cols-[260px_1fr] gap-10">

    <div>
      <a href="/" class="hover:text-gray-900">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">My Account</span>
      <h1 class="text-3xl font-black mb-2">My Account</h1>
      <p class="text-gray-500 mb-8">Manage your profile, settings, and preferences.</p>

      <%- include("../partials/accountSidebar", { active: "addresses" }) %>

    </div>

    <section class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="p-6 border-b border-gray-100">
        <h2 class="text-2xl font-black">Your Addresses</h2>
        <p class="text-sm text-gray-500 mt-1">Add or edit Addresses</p>
      </div>

      <div class="p-6">
        <% if (typeof msg !== "undefined" && msg) { %>
          <div class="mb-4 text-sm font-bold text-red-600"><%= msg %></div>
        <% } %>

        <div class="grid md:grid-cols-2 gap-6">
          <% (addresses || []).forEach(a => { %>
            <div class="rounded-2xl border border-indigo-100 bg-indigo-50/30 p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <div class="font-black text-indigo-700 text-lg"><%= a.fullName %></div>
                  <div class="text-indigo-700 text-sm mt-1"><%= a.phone %></div>

                  <div class="text-indigo-700 text-sm mt-3 leading-6">
                    <div><%= a.house %></div>
                    <div><%= a.area %></div>
                    <div><%= a.locality %>, <%= a.city %></div>
                    <div><%= a.state %> - <%= a.pincode %></div>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <!-- ✅ EDIT WORKS -->
                  <a href="/account/addresses/<%= a._id %>/edit" class="text-red-500 font-black hover:underline">
                    ✎ Edit
                  </a>

                  <form method="POST" action="/account/addresses/<%= a._id %>/delete"
                        onsubmit="return confirm('Delete this address?')">
                    <button class="text-gray-400 font-black hover:text-red-500" type="submit">✕</button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <div class="mt-10">
          <h3 class="font-black text-lg mb-4">+ Add a new Address</h3>

          <form method="POST" action="/account/addresses" class="grid md:grid-cols-2 gap-4">
            <input name="fullName" placeholder="Full Name" class="border rounded-xl px-4 py-3" required>
            <input name="phone" placeholder="Phone Number" class="border rounded-xl px-4 py-3" required>
            <input name="pincode" placeholder="Pincode" class="border rounded-xl px-4 py-3" required>
            <input name="state" placeholder="State" class="border rounded-xl px-4 py-3" required>
            <input name="city" placeholder="City / District" class="border rounded-xl px-4 py-3" required>
            <input name="locality" placeholder="Locality / Town" class="border rounded-xl px-4 py-3" required>
            <input name="house" placeholder="House No, Building, Company" class="border rounded-xl px-4 py-3 md:col-span-2" required>
            <input name="area" placeholder="Area, Colony, Street, Sector, Village" class="border rounded-xl px-4 py-3 md:col-span-2" required>

            <div class="md:col-span-2">
              <button class="px-6 py-3 rounded-xl bg-indigo-600 text-white font-black hover:bg-indigo-700">
                Save Address
              </button>
            </div>
          </form>
        </div>

      </div>
    </section>

  </div>
</div>
