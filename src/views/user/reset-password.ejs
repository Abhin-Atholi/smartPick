<div class="min-h-screen bg-gray-100 flex items-center justify-center p-5">
  <div class="w-full max-w-md bg-white rounded-xl shadow-lg border border-gray-100 p-8">
    <h1 class="text-2xl font-black text-center">Reset Password</h1>
    <p class="text-sm text-gray-500 text-center mt-1 mb-6">Enter OTP + new password</p>

    <div class="mb-6 text-center">
      <span class="text-xs font-bold uppercase tracking-wider text-gray-400">OTP Expires In</span>
      <div id="expiryTimer" class="text-2xl font-mono font-bold text-indigo-600">--:--</div>
    </div>

    <% if (msg) { %>
      <div class="mb-4 text-sm text-red-600 text-center font-semibold"><%= msg %></div>
    <% } %>

    <form method="POST" action="/reset-password" class="space-y-4">
      <input type="hidden" name="email" value="<%= email %>">

      <input name="otp" id="otpInput" maxlength="6" placeholder="6-digit OTP" required
        class="w-full text-center tracking-widest rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 outline-none focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100"/>

      <input name="password" type="password" placeholder="New password" required
        class="w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 outline-none focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100"/>

      <input name="confirmPassword" type="password" placeholder="Confirm password" required
        class="w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 outline-none focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100"/>

      <button id="submitBtn" class="w-full rounded-lg bg-indigo-600 text-white font-black py-3 hover:bg-indigo-700 transition disabled:bg-gray-400">
        Reset Password
      </button>
    </form>

    <form method="POST" action="/resend-reset-otp" class="mt-4">
      <input type="hidden" name="email" value="<%= email %>">
      <button
        id="resendBtn"
        type="submit"
        class="w-full rounded-lg border border-gray-200 bg-white py-3 font-bold hover:bg-gray-50 transition disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Resend OTP <span id="timerText"></span>
      </button>
    </form>

    <div class="mt-5 text-center text-sm">
      <a href="/login" class="font-bold hover:underline text-indigo-600">Back to Login</a>
    </div>
  </div>
</div>

<script>
  // Get time from backend (remainingSeconds should be calculated in loadResetPassword)
  let timeLeft = parseInt("<%= typeof remainingSeconds !== 'undefined' ? remainingSeconds : 0 %>") || 0;

  const expiryDisplay = document.getElementById("expiryTimer");
  const resendBtn = document.getElementById("resendBtn");
  const resendTimerText = document.getElementById("timerText");
  const submitBtn = document.getElementById("submitBtn");
  const otpInput = document.getElementById("otpInput");

  function startCountdown() {
    const timerInterval = setInterval(() => {
      if (timeLeft <= 0) {
        clearInterval(timerInterval);
        expiryDisplay.textContent = "EXPIRED";
        expiryDisplay.style.color = "red";
        
        if(submitBtn) submitBtn.disabled = true;
        if(otpInput) otpInput.disabled = true;
        resendBtn.disabled = false;
        resendTimerText.textContent = ""; 
      } else {
        const m = Math.floor(timeLeft / 60);
        const s = timeLeft % 60;
        expiryDisplay.textContent = `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
        
        resendBtn.disabled = true;
        resendTimerText.textContent = ` (Wait ${timeLeft}s)`;
        timeLeft--;
      }
    }, 1000);
  }

  if (timeLeft > 0) {
    startCountdown();
  } else {
    expiryDisplay.textContent = "EXPIRED";
    expiryDisplay.style.color = "red";
    resendBtn.disabled = false;
    if(submitBtn) submitBtn.disabled = true;
  }
</script>