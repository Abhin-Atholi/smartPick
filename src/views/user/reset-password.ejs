<div class="min-h-screen flex items-center justify-center bg-gray-100 p-5">
  <div class="w-full max-w-md bg-white rounded-xl shadow p-8">
    <h2 class="text-2xl font-black text-center mb-4">Reset Password</h2>

    <% if (msg) { %>
      <div class="text-red-500 text-sm mb-4 text-center"><%= msg %></div>
    <% } %>

    <form method="POST" action="/reset-password" class="space-y-4">
      <input type="hidden" name="email" value="<%= email %>">

      <input name="otp" type="text" placeholder="Enter OTP" required
        class="w-full border border-gray-200 rounded-lg px-4 py-3" />

      <input name="password" type="password" placeholder="New Password" required
        class="w-full border border-gray-200 rounded-lg px-4 py-3" />

      <input name="confirmPassword" type="password" placeholder="Confirm Password" required
        class="w-full border border-gray-200 rounded-lg px-4 py-3" />

      <button class="w-full bg-indigo-600 text-white font-black py-3 rounded-lg">
        Reset Password
      </button>
    </form>
  </div>
</div>
