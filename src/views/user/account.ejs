<%- include("../partials/navbar") %>

<section class="max-w-6xl mx-auto px-4 py-8">
  <%- include("../partials/accountHeader", { breadcrumb: 'Profile Details' }) %>

  <div class="grid lg:grid-cols-[280px_1fr] gap-6">
    <%- include("../partials/accountSidebar", { active: "profile" }) %>

    <main class="bg-white border border-gray-100 rounded-2xl shadow-sm p-8">
      
      <% if (typeof msg !== 'undefined' && msg) { %>
        <div class="mb-6 p-4 text-sm font-bold rounded-xl <%= msg.includes('successfully') ? 'bg-green-50 text-green-700 border border-green-100' : 'bg-red-50 text-red-700 border border-red-100' %>">
          <%= msg %>
        </div>
      <% } %>

      <div class="flex justify-between items-start mb-8">
        <div>
          <h2 class="text-xl font-black">Profile Details</h2>
          <p class="text-sm text-gray-500">Manage your public information.</p>
        </div>
        <button onclick="toggleModal('editProfileModal')" class="px-5 py-2 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition active:scale-95">
          Edit Profile
        </button>
      </div>

      <div class="flex items-center gap-6">
        <img class="w-24 h-24 rounded-full border object-cover shadow-sm" src="<%= (user && user.profileImage) ? user.profileImage : 'https://ui-avatars.com/api/?name=' + (user ? encodeURIComponent(user.fullName) : 'User') + '&background=6366f1&color=fff' %>" alt="avatar" referrerpolicy="no-referrer" onerror="this.src='https://ui-avatars.com/api/?name=User&background=6366f1&color=fff'">
        <div>
          <h3 class="text-2xl font-bold"><%= user.fullName %></h3>
          <p class="text-gray-500"><%= user.email %></p>
          <p class="text-sm text-indigo-600 font-semibold mt-1">
            <%= user.phone || 'No phone added' %>
          </p>
        </div>
      </div>
    </main>
  </div>
</section>

<div id="editProfileModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-white w-full max-w-lg rounded-2xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-200">
    <div class="p-6 border-b flex justify-between items-center">
      <h3 class="text-xl font-black">Edit Personal Information</h3>
      <button onclick="toggleModal('editProfileModal')" class="text-gray-400 hover:text-black transition">✕</button>
    </div>

    <form action="/account/update-profile" method="POST" enctype="multipart/form-data" class="p-6 space-y-4">
      <div>
        <label class="block text-sm font-bold mb-1 text-gray-700">Full Name</label>
        <input type="text" name="fullName" value="<%= user.fullName %>" required class="w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 outline-none bg-gray-50 focus:bg-white transition">
      </div>

      <div>
        <label class="block text-sm font-bold mb-1 text-gray-700">Email Address</label>
        <input type="email" name="email" value="<%= user.email %>" required class="w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 outline-none bg-gray-50 focus:bg-white transition">
      </div>

      <div>
        <label class="block text-sm font-bold mb-1 text-gray-700">Phone Number</label>
        <input type="text" name="phone" value="<%= user.phone || '' %>" class="w-full border rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 outline-none bg-gray-50 focus:bg-white transition">
      </div>

      <div>
        <label class="block text-sm font-bold mb-1 text-gray-700">Profile Picture</label>
        <div class="flex items-center gap-4 mb-3">
          <img id="preview" src="<%= (user && user.profileImage) ? user.profileImage : 'https://ui-avatars.com/api/?name=' + (user ? encodeURIComponent(user.fullName) : 'User') + '&background=6366f1&color=fff' %>" class="w-16 h-16 rounded-full border object-cover" referrerpolicy="no-referrer" onerror="this.src='https://ui-avatars.com/api/?name=User&background=6366f1&color=fff'">
          <% if (user.profileImage) { %>
            <button type="button" onclick="removeImage()" class="text-xs font-bold text-red-600 bg-red-50 px-3 py-1.5 rounded-lg hover:bg-red-100 transition">
              Remove Current Photo
            </button>
          <% } %>
        </div>
        <input type="file" name="profileImage" accept="image/*" onchange="previewImage(event)" class="text-sm block w-full text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer">
      </div>

      <div class="flex gap-3 pt-4 border-t">
        <button type="button" onclick="toggleModal('editProfileModal')" class="flex-1 py-3 border rounded-xl font-bold hover:bg-gray-50 transition">Cancel</button>
        <button type="submit" class="flex-1 py-3 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition shadow-lg shadow-indigo-100">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleModal(id) {
    const modal = document.getElementById(id);
    modal.classList.toggle('hidden');
  }

  function previewImage(event) {
    if (event.target.files && event.target.files[0]) {
      const reader = new FileReader();
      reader.onload = function() {
        const output = document.getElementById('preview');
        output.src = reader.result;
      }
      reader.readAsDataURL(event.target.files[0]);
    }
  }

  async function removeImage() {
    if (confirm("Delete your profile picture?")) {
      try {
        const response = await fetch('/account/remove-image', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });

        if (response.ok) {
          window.location.reload();
        } else {
          alert("Failed to remove image.");
        }
      } catch (err) {
        console.error("Error:", err);
        alert("An error occurred.");
      }
    }
  }
</script>