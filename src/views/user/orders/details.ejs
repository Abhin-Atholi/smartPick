<%- include("../partials/navbar") %>

<main class="bg-gray-50 min-h-screen py-10">
  <div class="max-w-5xl mx-auto px-4">

    <!-- Back Link + Invoice Buttons -->
    <div class="flex justify-between items-center mb-6">
      <a href="/orders" class="flex items-center gap-2 text-sm text-gray-500 hover:text-gray-800 font-semibold transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Orders
      </a>
      <div class="flex items-center gap-3">
        <button class="flex items-center gap-2 text-sm font-bold text-gray-600 hover:text-gray-900 border border-gray-200 bg-white px-4 py-2 rounded-xl transition hover:shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          View Invoice
        </button>
        <button class="flex items-center gap-2 text-sm font-bold text-white bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-xl transition shadow-sm shadow-indigo-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Invoice
        </button>
      </div>
    </div>

    <!-- Order Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-black text-gray-900">Order Details</h1>
      <div class="flex flex-wrap items-center gap-3 mt-2">
        <span class="text-lg font-black text-gray-800"><%= order.orderId || `#${order._id.toString().slice(-6).toUpperCase()}` %></span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold
          <%= order.orderStatus === 'Delivered' ? 'bg-green-100 text-green-700' :
              order.orderStatus === 'Cancelled' ? 'bg-red-100 text-red-700' :
              order.orderStatus === 'Shipped' ? 'bg-blue-100 text-blue-700' :
              order.orderStatus === 'Return Requested' || order.orderStatus === 'Returned' ? 'bg-orange-100 text-orange-700' :
              'bg-yellow-100 text-yellow-800' %>">
          <span class="w-1.5 h-1.5 rounded-full
            <%= order.orderStatus === 'Delivered' ? 'bg-green-500' :
                order.orderStatus === 'Cancelled' ? 'bg-red-500' :
                order.orderStatus === 'Shipped' ? 'bg-blue-500' :
                order.orderStatus === 'Return Requested' || order.orderStatus === 'Returned' ? 'bg-orange-500' :
                'bg-yellow-500' %>">
          </span>
          <%= order.orderStatus %>
        </span>
      </div>
      <p class="text-sm text-gray-400 mt-1">
        Placed on <%= new Date(order.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' }) %>
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-6">

      <!-- LEFT: Order Items + Address + Payment -->
      <div class="space-y-6">

        <!-- Order Items Card -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-base font-black text-gray-900">Order Items</h2>
          </div>
          <div class="divide-y divide-gray-100">
            <% order.items.forEach(item => { %>
              <% 
                const variant = item.product?.variants?.find(v => v.color && v.color.name === item.color);
                const imgUrl = variant?.images?.[0] || item.product?.variants?.[0]?.images?.[0] || '/placeholder.jpg';
              %>
              <div id="item-row-<%= item._id %>" class="flex gap-4 px-6 py-5 hover:bg-gray-50/50 transition-colors">
                <!-- Product Image -->
                <div class="w-20 h-24 rounded-xl overflow-hidden border border-gray-100 bg-gray-50 flex-shrink-0">
                  <img src="<%= imgUrl %>" class="w-full h-full object-cover">
                </div>

                <!-- Product Info -->
                <div class="flex-grow min-w-0">
                  <p class="text-sm font-black text-gray-900 mb-0.5"><%= item.product?.name || 'Product Unavailable' %></p>
                  <% if (item.product?.category) { %>
                    <p class="text-xs text-gray-400 mb-2"><%= item.product.category?.name || '' %></p>
                  <% } %>
                  <div class="flex flex-wrap gap-3 text-xs text-gray-500">
                    <span>Size: <span class="font-bold text-gray-700"><%= item.size %></span></span>
                    <span>Color: <span class="font-bold text-gray-700"><%= item.color %></span></span>
                  </div>

                  <!-- Item Status + Actions (below on mobile) -->
                  <div class="flex flex-wrap items-center gap-2 mt-3">
                    <span id="item-status-<%= item._id %>" class="text-xs font-bold px-2 py-1 rounded-full
                      <%= item.itemStatus === 'Delivered' ? 'bg-green-50 text-green-700' :
                          item.itemStatus === 'Cancelled' ? 'bg-red-50 text-red-700' :
                          item.itemStatus === 'Returned' || item.itemStatus === 'Return Requested' ? 'bg-orange-50 text-orange-700' :
                          item.itemStatus === 'Shipped' ? 'bg-blue-50 text-blue-700' :
                          'bg-yellow-50 text-yellow-700' %>">
                      <%= item.itemStatus %>
                    </span>

                    <% if (!['Shipped', 'Delivered', 'Cancelled', 'Returned', 'Return Requested'].includes(item.itemStatus)) { %>
                      <button onclick="openActionModal('cancel', '<%= order._id %>', '<%= item._id %>', 'Cancel Item')"
                        class="text-xs font-bold text-red-500 hover:text-red-700 hover:underline transition-colors px-1">
                        Cancel
                      </button>
                    <% } %>

                    <% if (item.itemStatus === 'Delivered') { %>
                      <button onclick="openActionModal('return', '<%= order._id %>', '<%= item._id %>', 'Return Item')"
                        class="text-xs font-bold text-orange-500 hover:text-orange-700 hover:underline transition-colors px-1">
                        Return
                      </button>
                    <% } %>
                  </div>
                </div>

                <!-- Price & Qty -->
                <div class="text-right flex-shrink-0">
                  <p class="text-base font-black text-indigo-600">₹<%= item.totalPrice.toLocaleString() %></p>
                  <p class="text-xs text-gray-400 mt-0.5">Qty: <%= item.quantity %></p>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Bottom row: Address + Payment side by side -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

          <!-- Delivery Address -->
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-7 h-7 bg-indigo-100 rounded-lg flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <h3 class="text-sm font-black text-gray-900">Delivery Address</h3>
            </div>
            <p class="text-sm font-black text-gray-900 leading-snug"><%= order.shippingAddress.fullName %></p>
            <p class="text-sm text-gray-500 mt-0.5"><%= order.shippingAddress.phone %></p>
            <div class="mt-3 text-sm text-gray-500 leading-relaxed">
              <p><%= order.shippingAddress.addressLine1 %></p>
              <% if (order.shippingAddress.addressLine2) { %><p><%= order.shippingAddress.addressLine2 %></p><% } %>
              <p><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> <%= order.shippingAddress.postalCode %></p>
              <p><%= order.shippingAddress.country %></p>
            </div>
          </div>

          <!-- Payment Information -->
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-7 h-7 bg-indigo-100 rounded-lg flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
              </div>
              <h3 class="text-sm font-black text-gray-900">Payment Information</h3>
            </div>
            <div class="space-y-3 text-sm">
              <div>
                <p class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Payment Method</p>
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 bg-indigo-600 rounded-md flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                  </div>
                  <span class="font-black text-gray-800"><%= order.paymentMethod %></span>
                </div>
              </div>
              <div>
                <p class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Payment Status</p>
                <span class="inline-flex items-center gap-1.5 text-sm font-bold
                  <%= order.paymentStatus === 'Paid' ? 'text-green-600' :
                      order.paymentStatus === 'Refunded' ? 'text-orange-600' :
                      order.paymentStatus === 'Failed' ? 'text-red-600' : 'text-yellow-600' %>">
                  <span class="w-2 h-2 rounded-full inline-block
                    <%= order.paymentStatus === 'Paid' ? 'bg-green-500' :
                        order.paymentStatus === 'Refunded' ? 'bg-orange-500' :
                        order.paymentStatus === 'Failed' ? 'bg-red-500' : 'bg-yellow-500' %>">
                  </span>
                  <%= order.paymentStatus %>
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Order Summary + Cancel/Return Order -->
      <div class="space-y-6">

        <!-- Order Summary -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
          <h2 class="text-base font-black text-gray-900 mb-5">Order Summary</h2>
          <div class="space-y-3">
            <div class="flex justify-between text-sm">
              <span class="text-gray-400 font-semibold">Subtotal</span>
              <span class="text-gray-800 font-bold">₹<%= order.subtotal.toLocaleString() %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-400 font-semibold">Shipping</span>
              <span class="text-gray-800 font-bold"><%= order.shippingFee === 0 ? 'Free' : `₹${order.shippingFee}` %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-400 font-semibold">Tax</span>
              <span class="text-gray-800 font-bold">₹<%= order.tax || 0 %></span>
            </div>
            <% if (order.discount > 0) { %>
            <div class="flex justify-between text-sm">
              <span class="text-gray-400 font-semibold">Discount</span>
              <span class="text-green-600 font-bold">-₹<%= order.discount.toLocaleString() %></span>
            </div>
            <% } %>
          </div>
          <div class="mt-5 pt-4 border-t border-dashed border-gray-200 flex justify-between items-end">
            <span class="text-sm font-black text-gray-900 uppercase tracking-wide">Total</span>
            <span class="text-2xl font-black text-indigo-600">₹<%= order.totalAmount.toLocaleString() %></span>
          </div>
        </div>

        <!-- Cancel / Return Order-level Actions -->
        <% if (!['Shipped', 'Delivered', 'Cancelled', 'Returned', 'Return Requested'].includes(order.orderStatus)) { %>
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
          <h2 class="text-base font-black text-gray-900 mb-1">Cancel Order?</h2>
          <p class="text-sm text-gray-400 mb-4">Do you want to cancel the entire order?</p>
          <button onclick="openActionModal('cancel', '<%= order._id %>', null, 'Cancel Entire Order')"
            class="w-full py-3 bg-red-500 hover:bg-red-600 text-white rounded-xl font-bold text-sm transition-all shadow-sm shadow-red-100 active:scale-95">
            Cancel Order
          </button>
        </div>
        <% } %>

        <% if (order.orderStatus === 'Delivered') { %>
        <div class="bg-white rounded-2xl border border-orange-200 shadow-sm p-6">
          <h2 class="text-base font-black text-gray-900 mb-1">Return Order?</h2>
          <p class="text-sm text-gray-400 mb-4">Request a return for the entire order.</p>
          <button onclick="openActionModal('return', '<%= order._id %>', null, 'Return Entire Order')"
            class="w-full py-3 bg-orange-500 hover:bg-orange-600 text-white rounded-xl font-bold text-sm transition-all shadow-sm shadow-orange-100 active:scale-95">
            Return Order
          </button>
        </div>
        <% } %>

      </div>
    </div>

  </div>
</main>

<!-- Action Modal (Cancel / Return) -->
<div id="actionModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-white w-full max-w-md rounded-2xl shadow-2xl flex flex-col overflow-hidden">
    <div class="p-6 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
      <h3 id="actionModalTitle" class="text-lg font-black text-gray-900">Action</h3>
      <button onclick="closeActionModal()" class="text-gray-400 hover:text-black transition text-xl leading-none">✕</button>
    </div>
    <form id="actionForm" class="p-6 space-y-4">
      <input type="hidden" id="actionType">
      <input type="hidden" id="actionOrderId">
      <input type="hidden" id="actionItemId">

      <div class="space-y-2">
        <label class="text-sm font-bold text-gray-700">
          Reason <span id="reasonAsterisk" class="text-red-500 hidden">*</span>
          <span id="reasonOptional" class="text-gray-400 font-normal text-xs ml-1">(optional)</span>
        </label>
        <textarea id="actionReason" rows="3" placeholder="Please provide a reason..."
          class="w-full border border-gray-200 rounded-xl px-4 py-3 outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 bg-gray-50 focus:bg-white transition resize-none text-sm"></textarea>
      </div>

      <div class="flex gap-3 pt-2 border-t border-gray-100">
        <button type="button" onclick="closeActionModal()"
          class="flex-1 py-3 border border-gray-200 text-gray-700 rounded-xl font-bold text-sm hover:bg-gray-50 transition">
          Go Back
        </button>
        <button type="submit" id="actionSubmitBtn"
          class="flex-1 py-3 rounded-xl font-bold text-sm text-white transition shadow-lg bg-red-600 hover:bg-red-700 shadow-red-100">
          Confirm
        </button>
      </div>
    </form>
  </div>
</div>

<%- include("../partials/footer") %>
<%- include("../partials/drawer") %>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  // Toast helper
  const toast = (icon, title, text) => Swal.fire({
    icon, title, text, toast: true, position: 'top-end',
    showConfirmButton: false, timer: 3000, timerProgressBar: true
  });

  function openActionModal(type, orderId, itemId, title) {
    document.getElementById('actionModalTitle').innerText = title;
    document.getElementById('actionType').value = type;
    document.getElementById('actionOrderId').value = orderId;
    document.getElementById('actionItemId').value = itemId || '';
    document.getElementById('actionReason').value = '';

    const btn = document.getElementById('actionSubmitBtn');
    const reasonAsterisk = document.getElementById('reasonAsterisk');
    const reasonOptional = document.getElementById('reasonOptional');
    const reasonField = document.getElementById('actionReason');

    if (type === 'cancel') {
      btn.className = 'flex-1 py-3 rounded-xl font-bold text-sm text-white transition shadow-lg bg-red-600 hover:bg-red-700 shadow-red-100';
      reasonField.required = false;
      reasonAsterisk.classList.add('hidden');
      reasonOptional.classList.remove('hidden');
    } else {
      btn.className = 'flex-1 py-3 rounded-xl font-bold text-sm text-white transition shadow-lg bg-orange-500 hover:bg-orange-600 shadow-orange-100';
      reasonField.required = true;
      reasonAsterisk.classList.remove('hidden');
      reasonOptional.classList.add('hidden');
    }

    document.getElementById('actionModal').classList.remove('hidden');
  }

  function closeActionModal() {
    document.getElementById('actionModal').classList.add('hidden');
  }

  document.getElementById('actionForm').addEventListener('submit', async function (e) {
    e.preventDefault();
    const type = document.getElementById('actionType').value;
    const orderId = document.getElementById('actionOrderId').value;
    const itemId = document.getElementById('actionItemId').value;
    const reason = document.getElementById('actionReason').value;

    if (type === 'return' && !reason.trim()) {
      return toast('warning', 'Reason Required', 'Please provide a reason for your return request.');
    }

    const btn = document.getElementById('actionSubmitBtn');
    const originalText = btn.innerText;
    btn.innerText = 'Processing...';
    btn.disabled = true;

    try {
      const endpoint = type === 'cancel' ? '/order/cancel' : '/order/return';
      const payload = { orderId, reason };
      if (itemId) payload.itemId = itemId;

      const res = await axios.post(endpoint, payload);

      if (res.data.success) {
        closeActionModal();
        await Swal.fire({ icon: 'success', title: 'Done!', text: res.data.message, timer: 1800, showConfirmButton: false });
        window.location.reload();
      }
    } catch (err) {
      closeActionModal();
      Swal.fire({ icon: 'error', title: 'Failed', text: err.response?.data?.message || 'Something went wrong.' });
    } finally {
      btn.innerText = originalText;
      btn.disabled = false;
    }
  });

  document.getElementById('actionModal').addEventListener('click', function (e) {
    if (e.target === this) closeActionModal();
  });
</script>
