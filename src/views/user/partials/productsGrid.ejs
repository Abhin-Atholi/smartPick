<!-- PARTIAL: productsGrid -->

<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
  <% if (typeof products !=='undefined' && products.length> 0) { %>
    <% products.forEach(p=> { %>
      <% const minPrice=p.variants && p.variants.length> 0
        ? Math.min(...p.variants.map(v => v.price))
        : 0;
        const formattedPrice = `₹${minPrice.toLocaleString()}`;
        const firstImage = p.images && p.images.length > 0 ? p.images[0] : 'https://placehold.co/600x700?text=No+Image';
        const catName = p.category ? p.category.name : 'Uncategorized';
        %>
        <article class="bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow group flex flex-col h-full relative">
          <div class="relative bg-gray-50 aspect-[4/5] overflow-hidden">
            <% if(p.isFeatured){ %>
              <span class="absolute left-3 top-3 z-10 text-[10px] font-black bg-amber-500 text-white px-3 py-1 rounded-full uppercase tracking-widest shadow-sm">Featured</span>
            <% } %>
            <a href="/products/details/<%= p._id %>" class="block w-full h-full">
              <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                src="<%= firstImage %>" alt="<%= p.name %>" loading="lazy">
            </a>
            
            <!-- Wishlist Heart Button -->
            <button onclick="toggleWishlist(this, '<%= p._id %>')" 
                    class="absolute top-3 right-3 z-10 w-8 h-8 rounded-full bg-white/80 backdrop-blur-sm border border-gray-100 flex items-center justify-center transition-all hover:bg-white <%= (typeof wishlistProductIds !== 'undefined' && wishlistProductIds.includes(p._id.toString())) ? 'text-red-500 border-red-100 shadow-sm' : 'text-gray-400' %>">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" 
                   fill="<%= (typeof wishlistProductIds !== 'undefined' && wishlistProductIds.includes(p._id.toString())) ? 'currentColor' : 'none' %>" 
                   stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
            </button>
          </div>

          <div class="p-5 flex flex-col flex-1">
            <div class="mb-3">
              <a href="/products/details/<%= p._id %>">
                <h3 class="font-black text-slate-800 text-sm truncate hover:text-indigo-600 transition-colors">
                  <%= p.name %>
                </h3>
              </a>
              <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider mt-0.5"><%= catName %></p>
            </div>

            <!-- Variants Preview: Sizes & Colors -->
            <div class="flex flex-col gap-3 mb-4 mt-auto">
              <% 
                const uniqueSizes = [...new Set(p.variants.map(v => v.size))].sort((a,b) => ["S","M","L","XL"].indexOf(a) - ["S","M","L","XL"].indexOf(b));
                const uniqueColors = Array.from(new Set(p.variants.map(v => JSON.stringify(v.color)))).map(c => JSON.parse(c));
              %>
              <div class="flex gap-1.5 flex-wrap">
                <% uniqueColors.slice(0, 5).forEach(c => { %>
                  <span class="w-3 h-3 rounded-full border border-gray-100 shadow-sm" style="background-color: <%= c.code %>" title="<%= c.name %>"></span>
                <% }) %>
                <% if(uniqueColors.length > 5) { %>
                  <span class="text-[9px] font-black text-gray-400">+<%= uniqueColors.length - 5 %></span>
                <% } %>
              </div>
              <div class="text-[10px] font-black text-slate-400 tracking-widest uppercase">
                <%= uniqueSizes.join(', ') %>
              </div>
            </div>

            <div class="pt-4 border-t border-gray-50 flex items-center justify-between gap-2">
              <div>
                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-tighter">Price</p>
                <p class="font-black text-base text-slate-900"><%= formattedPrice %></p>
              </div>
              <button onclick="addToCart('<%= p._id %>', this)" 
                class="px-4 py-2 bg-indigo-50 text-indigo-600 text-[10px] font-black rounded-xl hover:bg-indigo-600 hover:text-white transition-all uppercase tracking-wider whitespace-nowrap">
                Add to cart
              </button>
            </div>
          </div>
        </article>
        <% }) %>
          <% } else { %>
            <div class="col-span-full py-20 text-center bg-gray-50 rounded-3xl border-2 border-dashed border-gray-100">
              <div class="text-5xl mb-4">📦</div>
              <p class="text-gray-400 font-bold">No products found for this criteria.</p>
              <a href="/products" class="text-indigo-600 hover:underline mt-2 inline-block">Browse all →</a>
            </div>
            <% } %>
</div>