<!-- PARTIAL: productsGrid -->

<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
  <% const products = [
    {name:"Classic Cotton Tee", cat:"Men's Apparel", price:"₹2,399", seed:"t1", badge:"New"},
    {name:"Floral Summer Dress", cat:"Women's Apparel", price:"₹6,499", seed:"d1"},
    {name:"Floral Summer Dress", cat:"Women's Apparel", price:"₹6,499", seed:"d2"},
    {name:"Classic Cotton Tee", cat:"Men's Apparel", price:"₹2,399", seed:"t2", badge:"New"},
    {name:"Floral Summer Dress", cat:"Women's Apparel", price:"₹6,499", seed:"d3"},
    {name:"Floral Summer Dress", cat:"Women's Apparel", price:"₹6,499", seed:"d4"},
  ]; %>

  <% products.forEach(p => { %>
    <article class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm">
      <div class="relative bg-gray-100">
        <% if(p.badge){ %>
          <span class="absolute left-3 top-3 text-xs font-black bg-indigo-600 text-white px-3 py-1 rounded-full"><%= p.badge %></span>
        <% } %>
        <button class="absolute right-3 top-3 w-8 h-8 rounded-full bg-white border border-gray-200 grid place-items-center">♡</button>
        <img class="w-full h-64 object-cover" src="https://picsum.photos/seed/<%= p.seed %>/600/700" alt="product">
      </div>

      <div class="p-4">
        <div class="flex justify-between items-start gap-2">
          <div>
            <h3 class="font-bold text-sm"><%= p.name %></h3>
            <div class="text-xs text-gray-500 mt-1"><%= p.cat %></div>
          </div>
          <div class="text-gray-400">• •</div>
        </div>

        <div class="flex justify-between items-center mt-3 mb-3">
          <div class="font-black"><%= p.price %></div>
          <div class="text-xs text-gray-400">XS - L</div>
        </div>

        <button class="w-full rounded-full bg-indigo-600 text-white font-black py-2 text-sm hover:bg-indigo-700 transition">
          Add to Cart
        </button>
      </div>
    </article>
  <% }) %>
</div>
