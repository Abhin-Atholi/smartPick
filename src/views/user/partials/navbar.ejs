<%
  /*
   * navActive(href)
   * Returns Tailwind classes that underline / highlight the matching nav link.
   * Works with both plain paths ('/')  AND query-string hrefs
   * ('/products?category=Top') because currentPath is now req.originalUrl.
   */
  function navActive(href) {
    const cp = typeof currentPath !== 'undefined' ? currentPath : '';
    let isActive;
    if (href === '/') {
      // Home: exact match on path portion only
      const pathOnly = cp.split('?')[0];
      isActive = pathOnly === '/' || pathOnly === '/home';
    } else if (href.includes('?')) {
      // Category link: full URL must start with this href
      isActive = cp === href || cp.startsWith(href + '&') || cp.startsWith(href + '#');
    } else {
      isActive = cp.startsWith(href);
    }
    return isActive
      ? 'text-indigo-600 border-b-2 border-indigo-600'
      : 'text-gray-500 hover:text-gray-900 border-b-2 border-transparent';
  }
%>

<header class="bg-white border-b border-gray-200 sticky top-0 z-20 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center gap-4">

    <!-- ☰ Drawer toggle -->
    <button data-drawer-open class="w-10 h-10 rounded-xl hover:bg-gray-100 grid place-items-center text-gray-600 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" y1="6" x2="20" y2="6"/>
        <line x1="4" y1="12" x2="20" y2="12"/>
        <line x1="4" y1="18" x2="20" y2="18"/>
      </svg>
    </button>

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0">
      <div class="w-7 h-7 rounded-xl bg-indigo-600 text-white font-black grid place-items-center text-sm shadow-sm shadow-indigo-300">S</div>
      <span class="font-black text-indigo-600 tracking-tight">SmartPick</span>
    </a>

    <!-- Desktop Nav Links -->
    <nav class="hidden lg:flex items-center gap-5 text-sm font-bold ml-4">

      <!-- Home -->
      <a href="/" class="pb-1 transition-colors <%= navActive('/') %>">
        Home
      </a>

      <!-- Dynamic categories from DB -->
      <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
        <% categories.forEach(cat => { %>
          <a href="/products?category=<%= encodeURIComponent(cat.name) %>"
             class="pb-1 transition-colors <%= navActive('/products?category=' + encodeURIComponent(cat.name)) %>">
            <%= cat.name %>
          </a>
        <% }) %>
      <% } %>

    </nav>

    <!-- Right-side actions -->
    <div class="flex items-center gap-1 ml-auto">
      <% if (typeof isAuth !== "undefined" && isAuth) { %>

        <!-- Wallet -->
        <button class="w-10 h-10 rounded-xl hover:bg-indigo-50 hover:text-indigo-600 text-gray-500 grid place-items-center transition-colors" title="Wallet">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="5" width="20" height="14" rx="3"/>
            <path d="M16 12h2"/>
            <path d="M2 10h20"/>
          </svg>
        </button>

        <!-- Wishlist -->
        <a href="/wishlist" class="w-10 h-10 rounded-xl hover:bg-indigo-50 hover:text-indigo-600 text-gray-500 grid place-items-center transition-colors" title="Wishlist">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </a>

        <!-- Cart with badge -->
        <a href="/cart" class="w-10 h-10 rounded-xl hover:bg-indigo-50 hover:text-indigo-600 text-gray-500 grid place-items-center relative transition-colors" title="Cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span id="cartBadge" class="absolute top-1 right-1 text-[10px] bg-indigo-600 text-white px-1.5 rounded-full leading-none py-0.5">
            <%= (typeof cart !== 'undefined' && cart.totalItems !== undefined) ? cart.totalItems : (typeof cart !== 'undefined' && cart.items ? cart.items.length : 0) %>
          </span>
        </a>

        <!-- Logout -->
        <a href="/logout" onclick="confirmLogout(event, this.href)"
           class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-red-200 text-red-500 font-black text-sm hover:bg-red-50 transition-colors ml-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Log Out
        </a>

      <% } else { %>
        <a href="/login"
           class="px-5 py-2 rounded-full border border-gray-200 font-black text-sm hover:bg-gray-50 transition-colors">
          Login
        </a>
      <% } %>
    </div>

  </div>
</header>